@{
    var activeSlug  = ViewBag.CurrentCategory as string ?? "";
    var activeMode  = ViewBag.Mode as string ?? "";
    var userId      = ViewBag.UserId as int?;
    var role        = ViewBag.Role as string;

    // Determine current active link from request path
    var path = Context.Request.Path.Value ?? "";
    var isWiki    = path.Contains("/SafeWiki",    StringComparison.OrdinalIgnoreCase);
    var isHotline = path.Contains("/Hotline",     StringComparison.OrdinalIgnoreCase);
    var isCreate  = path.Contains("/Create",      StringComparison.OrdinalIgnoreCase);
    var isMy      = activeMode == "my";
    var isAnNinh  = activeSlug == "an-ninh";
    var isDoiSong = activeSlug == "doi-song";
    var isHome    = activeMode == "home" || (!isAnNinh && !isDoiSong && !isWiki && !isHotline && !isMy && !isCreate);
}

<nav class="art-subnav">
    <div class="art-subnav__inner">
        <!-- Left: category links -->
        <a href="/Article" class="@(isHome ? "active" : "")">🏠 Trang chủ</a>
        <a href="/Article/Index?categorySlug=an-ninh" class="@(isAnNinh ? "active" : "")">🛡️ An ninh</a>
        <a href="/Article/Index?categorySlug=doi-song" class="@(isDoiSong ? "active" : "")">🏘️ Đời sống</a>
        <a href="/Article/SafeWiki" class="@(isWiki ? "active" : "")">📖 SafeWiki</a>
        <a href="/Article/Hotline" class="@(isHotline ? "active" : "")">📞 Hotline</a>
        @if (userId != null && role != "Admin")
        {
            <a href="/Article/Index?mode=my" class="@(isMy || isCreate ? "active" : "")">📝 Tin của tôi</a>
        }

        <!-- Right: search + today's date -->
        <div class="art-subnav__right">
            <div class="art-subnav-search">
                <svg viewBox="0 0 24 24" width="14" height="14"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input id="subnav-search" type="text" placeholder="Tìm kiếm..." onkeydown="if(event.key==='Enter'){ window.location='/Article?q='+encodeURIComponent(this.value); }" />
            </div>
            <div class="art-subnav-date" id="subnav-date"></div>
        </div>
    </div>
</nav>

<script>
(function(){
    var d = new Date();
    var days = ['Chủ Nhật','Thứ Hai','Thứ Ba','Thứ Tư','Thứ Năm','Thứ Sáu','Thứ Bảy'];
    var dd = String(d.getDate()).padStart(2,'0');
    var mm = String(d.getMonth()+1).padStart(2,'0');
    var yyyy = d.getFullYear();
    document.getElementById('subnav-date').textContent = days[d.getDay()] + ', ' + dd + '/' + mm + '/' + yyyy;
})();
</script>
