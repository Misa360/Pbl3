    @{
    ViewData["Title"] = "SafeWiki - Cẩm nang an toàn";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/article.css" />
<div class="article-page-wrapper">

    @await Html.PartialAsync("_ArticleSubNav")

    <div class="article-container safewiki-container">
        <div class="safewiki-header">
            <span class="safewiki-eyebrow">Cẩm nang an toàn</span>
            <h1>📖 SafeWiki — Cẩm nang An toàn</h1>
            <p>Lật từng trang để tìm hiểu các kiến thức an toàn quan trọng tại Đà Nẵng</p>
            <div class="safewiki-hint">
                <span>💡 Nhấp vào góc sách hoặc kéo thanh trượt bên dưới để chuyển trang</span>
            </div>
        </div>

        <!-- FLIPBOOK STAGE -->
        <div class="safewiki-stage">
            <button type="button" class="safewiki-nav safewiki-nav--prev" aria-label="Trang trước" onclick="$('.sample-docs').turn('previous');">‹</button>

            <div id="canvas" style="visibility: hidden;">
                <div id="book-zoom">
                    <div class="sample-docs"></div>
                    <div class="hard"></div>
                    <div class="hard"></div>
                    <div class="hard p11"></div>
                    <div class="hard p12"></div>
                </div>
            </div>

            <button type="button" class="safewiki-nav safewiki-nav--next" aria-label="Trang sau" onclick="$('.sample-docs').turn('next');">›</button>
        </div>

        <div id="slider-bar" class="turnjs-slider">
            <div id="slider"></div>
        </div>

        <div class="safewiki-footnote">
            <div>
                <strong>Về SafeWiki</strong>
                <p>SafeWiki là tuyển tập các kiến thức an toàn được biên soạn dành riêng cho người dân và du khách tại Đà Nẵng. Tài liệu được cập nhật thường xuyên bởi đội ngũ biên tập DaNang SafeMap.</p>
            </div>
            <div class="safewiki-footnote-links">
                <a href="/Article/Hotline">📞 Các số hotline khẩn cấp</a>
                <a href="/Article">📰 Quay lại trang tin tức</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/article.js"></script>

    <!-- Flipbook Dependencies -->
    <script src="~/files/extras/jquery.min.1.7.js"></script>
    <script src="~/files/extras/jquery-ui-1.8.20.custom.min.js"></script>
    <script src="~/files/extras/jquery.mousewheel.min.js"></script>
    <script src="~/files/extras/modernizr.2.5.3.min.js"></script>
    <script src="~/files/lib/hash.js"></script>

    <!-- Flipbook CSS -->
    <link rel="stylesheet" href="~/files/css/docs.css" />
    <link rel="stylesheet" href="~/files/css/jquery.ui.css" />

    <!-- Flipbook Core + App Logic -->
    <script src="~/files/lib/turn.min.js"></script>
    <script src="~/files/js/docs.js"></script>

    <style>
        /* ── Override docs.css rules that break the page layout ─────────────
           docs.css sets `body { overflow:hidden }` and `#canvas { margin:100px auto }`.
           Those rules hide the bottom of the page (slider, footnote) because the
           body can't scroll. Restore normal scroll + strip the rogue margin. */
        html, body { overflow: auto !important; height: auto !important; }

        .safewiki-container {
            padding-top: 28px;
            padding-bottom: 64px;
        }
        .safewiki-header {
            text-align: center;
            margin-bottom: 28px;
        }
        .safewiki-eyebrow {
            display: inline-block;
            background: var(--art-accent, #2D6A4F);
            color: #fff;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 4px 14px;
            border-radius: 16px;
            margin-bottom: 12px;
        }
        .safewiki-header h1 {
            font-family: var(--art-serif, Georgia, serif);
            font-size: 32px;
            color: var(--art-accent, #2D6A4F);
            margin: 0 0 8px;
            line-height: 1.25;
        }
        .safewiki-header p {
            color: var(--art-text-muted, #888);
            font-size: 15px;
            margin: 0;
        }
        .safewiki-hint {
            margin-top: 14px;
            display: inline-block;
            background: #fff8e1;
            border: 1px solid #ffe08a;
            color: #8b6508;
            font-size: 13px;
            padding: 6px 14px;
            border-radius: 20px;
        }

        /* Stage holds canvas centered with side nav buttons */
        .safewiki-stage {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 20px;
        }
        .safewiki-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 44px;
            height: 44px;
            border-radius: 50%;
            border: none;
            background: var(--art-accent, #2D6A4F);
            color: #fff;
            font-size: 24px;
            line-height: 1;
            cursor: pointer;
            box-shadow: 0 4px 14px rgba(0,0,0,0.18);
            z-index: 5;
            transition: transform 0.15s ease, background 0.15s ease;
        }
        .safewiki-nav:hover { background: var(--art-accent-dark, #1B4332); transform: translateY(-50%) scale(1.05); }
        .safewiki-nav--prev { left: 8px; }
        .safewiki-nav--next { right: 8px; }

        /* Core flipbook sizing — override docs.css `margin: 100px auto` */
        #canvas {
            width: 960px;
            height: 620px;
            margin: 0 auto !important;
        }
        .sample-docs {
            margin-top: 20px;
            width: 942px;
            height: 600px;
        }
        .sample-docs .page {
            width: 471px;
            height: 600px;
            background: white;
            box-shadow: 0 0 20px rgba(0,0,0,0.2);
        }
        .sample-docs .hard {
            background-image: url('/files/pics/covers.jpg');
        }
        .sample-docs .p2 { background-position: -471px 0; }
        .sample-docs .p28 {
            background: linear-gradient(to right, #fff 95%, #dadada 100%);
        }
        .sample-docs .p29 { background-position: -942px 0; }
        .sample-docs .p30 { background-position: -1413px 0; }
        .sample-docs .even .gradient {
            position:absolute; top:0; left:0; width:100%; height:100%;
            background-image:url('/files/pics/right-border.png');
            background-position:right top; background-repeat: repeat-y;
        }
        .sample-docs .odd .gradient {
            position:absolute; top:0; left:0; width:100%; height:100%;
            background-image:url('/files/pics/left-border.png');
            background-position:left top; background-repeat: repeat-y;
        }
        .sample-docs .loader {
            background-image:url('/files/pics/loader.gif');
            width:22px; height:22px; position:absolute; top:280px; left:219px;
        }

        .turnjs-slider {
            width: min(560px, 90%);
            margin: 0 auto;
            padding: 12px 16px;
            background: #fff;
            border: 1px solid var(--art-border, #e0e0e0);
            border-radius: 999px;
            box-shadow: var(--art-shadow, 0 2px 8px rgba(0,0,0,0.08));
        }
        #slider { margin: 0 auto; }
        .ui-slider {
            background: #e6e6e6;
            border-radius: 4px;
            height: 6px;
            position: relative;
        }
        .ui-slider-handle {
            background: var(--art-accent, #2D6A4F);
            border: 2px solid #fff;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            position: absolute;
            top: -8px;
            cursor: pointer;
            outline: none;
            box-shadow: 0 2px 6px rgba(0,0,0,0.2);
        }

        .safewiki-footnote {
            margin-top: 36px;
            background: #fff;
            border: 1px solid var(--art-border, #e0e0e0);
            border-radius: 10px;
            padding: 20px 24px;
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
            align-items: center;
        }
        .safewiki-footnote strong {
            display: block;
            font-family: var(--art-serif, Georgia, serif);
            font-size: 18px;
            color: var(--art-accent, #2D6A4F);
            margin-bottom: 6px;
        }
        .safewiki-footnote p {
            margin: 0;
            color: var(--art-text-secondary, #555);
            font-size: 14px;
            line-height: 1.6;
        }
        .safewiki-footnote-links { display: flex; flex-direction: column; gap: 10px; }
        .safewiki-footnote-links a {
            display: inline-block;
            padding: 10px 14px;
            border-radius: 8px;
            background: var(--art-bg, #f5f5f0);
            color: var(--art-accent-dark, #1B4332);
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            border: 1px solid var(--art-border, #e0e0e0);
            transition: background 0.15s;
        }
        .safewiki-footnote-links a:hover { background: #eef3ef; }

        /* Responsive — scale the book down instead of overflowing */
        @@media (max-width: 1024px) {
            #canvas {
                width: 100%;
                max-width: 720px;
                height: auto;
                aspect-ratio: 960 / 620;
                transform-origin: top center;
            }
            .safewiki-nav { width: 38px; height: 38px; font-size: 20px; }
        }
        @@media (max-width: 720px) {
            .safewiki-header h1 { font-size: 24px; }
            .safewiki-nav--prev { left: 2px; }
            .safewiki-nav--next { right: 2px; }
            .safewiki-footnote {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <script>
        // Initialize flipbook after all scripts loaded
        (function () {
            function initFlipbook() {
                var flipbook = $('.sample-docs');

                // Wait for CSS to load
                if (flipbook.width() == 0 || flipbook.height() == 0) {
                    setTimeout(initFlipbook, 50);
                    return;
                }

                // Mousewheel navigation
                $('#book-zoom').mousewheel(function (event, delta, deltaX, deltaY) {
                    var data = $(this).data(),
                        step = 30,
                        flipbook = $('.sample-docs'),
                        actualPos = $('#slider').slider('value') * step;

                    if (typeof (data.scrollX) === 'undefined') {
                        data.scrollX = actualPos;
                        data.scrollPage = flipbook.turn('page');
                    }

                    data.scrollX = Math.min($("#slider").slider('option', 'max') * step,
                        Math.max(0, data.scrollX + deltaX));

                    var actualView = Math.round(data.scrollX / step),
                        page = Math.min(flipbook.turn('pages'), Math.max(1, actualView * 2 - 2));

                    if ($.inArray(data.scrollPage, flipbook.turn('view', page)) == -1) {
                        data.scrollPage = page;
                        flipbook.turn('page', page);
                    }

                    if (data.scrollTimer) clearInterval(data.scrollTimer);
                    data.scrollTimer = setTimeout(function () {
                        data.scrollX = undefined;
                        data.scrollPage = undefined;
                        data.scrollTimer = undefined;
                    }, 1000);
                });

                // Slider
                $("#slider").slider({
                    min: 1,
                    max: 100,
                    start: function (event, ui) {
                        if (!window._thumbPreview) {
                            _thumbPreview = $('<div />', { 'class': 'thumbnail' }).html('<div></div>');
                            setPreview(ui.value);
                            _thumbPreview.appendTo($(ui.handle));
                        } else
                            setPreview(ui.value);
                        moveBar(false);
                    },
                    slide: function (event, ui) {
                        setPreview(ui.value);
                    },
                    stop: function () {
                        if (window._thumbPreview)
                            _thumbPreview.removeClass('show');
                        $('.sample-docs').turn('page', Math.max(1, $(this).slider('value') * 2 - 2));
                    }
                });

                // Keyboard arrows
                $(document).keydown(function (e) {
                    if (e.keyCode === 37) { $('.sample-docs').turn('previous'); }
                    else if (e.keyCode === 39) { $('.sample-docs').turn('next'); }
                });

                // Create the flipbook
                flipbook.turn({
                    elevation: 50,
                    acceleration: false,
                    gradients: true,
                    autoCenter: true,
                    duration: 1000,
                    pages: 12,
                    when: {
                        turning: function (e, page, view) {
                            var book = $(this),
                                currentPage = book.turn('page'),
                                pages = book.turn('pages');

                            if (currentPage > 3 && currentPage < pages - 3) {
                                if (page == 1) {
                                    book.turn('page', 2).turn('stop').turn('page', page);
                                    e.preventDefault(); return;
                                } else if (page == pages) {
                                    book.turn('page', pages - 1).turn('stop').turn('page', page);
                                    e.preventDefault(); return;
                                }
                            }
                            Hash.go('page/' + page).update();
                        },
                        turned: function (e, page, view) {
                            var book = $(this);
                            $('#slider').slider('value', getViewNumber(book, page));
                            book.turn('center');
                        },
                        start: function (e, pageObj) { moveBar(true); },
                        end: function (e, pageObj) {
                            var book = $(this);
                            setTimeout(function () {
                                $('#slider').slider('value', getViewNumber(book));
                            }, 1);
                            moveBar(false);
                        },
                        missing: function (e, pages) {
                            for (var i = 0; i < pages.length; i++)
                                addPage(pages[i], $(this));
                        }
                    }
                }).turn('page', 2);

                $('#slider').slider('option', 'max', numberOfViews(flipbook));
                flipbook.addClass('animated');

                // Show canvas
                $('#canvas').css({ visibility: 'visible' });
            }

            // Wait for jQuery and turn.js to be ready, then init
            function waitAndInit() {
                if (typeof $ !== 'undefined' && $.fn && $.fn.turn) {
                    initFlipbook();
                } else {
                    setTimeout(waitAndInit, 100);
                }
            }
            waitAndInit();
        })();
    </script>
}
