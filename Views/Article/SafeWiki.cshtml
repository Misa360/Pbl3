@{
    ViewData["Title"] = "SafeWiki - Cẩm nang an toàn";
    Layout = "_Layout";
}

@* SafeWiki — kiểu "đọc sách toàn màn hình".
   Theo yêu cầu: bỏ hết text xung quanh, chỉ giữ cuốn sách, fit vào viewport
   (không phải scroll lên xuống để thấy hết). *@
<link rel="stylesheet" href="~/css/article.css" />

<div class="safewiki-fullscreen">
    @await Html.PartialAsync("_ArticleSubNav")

    <div class="safewiki-stage">
        <div id="canvas">
            <div id="book-zoom">
                <div class="sample-docs"></div>
                <div class="hard"></div>
                <div class="hard"></div>
                <div class="hard p11"></div>
                <div class="hard p12"></div>
            </div>
        </div>

        @* Top-right icon cluster: sound toggle + fullscreen *@
        <div class="safewiki-tools">
            <button type="button" class="safewiki-tool" id="safewikiSoundBtn"
                    aria-label="Tắt/bật tiếng" title="Tắt/bật tiếng lật trang">
                <svg class="safewiki-tool__icon safewiki-tool__icon--on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                    <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
                </svg>
                <svg class="safewiki-tool__icon safewiki-tool__icon--off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                    <line x1="23" y1="9" x2="17" y2="15"/>
                    <line x1="17" y1="9" x2="23" y2="15"/>
                </svg>
            </button>
            <button type="button" class="safewiki-tool" id="safewikiFullBtn"
                    aria-label="Toàn màn hình" title="Toàn màn hình">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
                </svg>
            </button>
        </div>

        @* Prev/next buttons at bottom center, side by side *@
        <div class="safewiki-pager">
            <button type="button" class="safewiki-nav safewiki-nav--prev"
                    aria-label="Trang trước"
                    onclick="if(window.SafeWikiFlip){SafeWikiFlip.unlock();SafeWikiFlip.play();} $('.sample-docs').turn('previous');">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 18l-6-6 6-6"/>
                </svg>
            </button>
            <button type="button" class="safewiki-nav safewiki-nav--next"
                    aria-label="Trang sau"
                    onclick="if(window.SafeWikiFlip){SafeWikiFlip.unlock();SafeWikiFlip.play();} $('.sample-docs').turn('next');">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 6l6 6-6 6"/>
                </svg>
            </button>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/article.js"></script>

    <!-- Flipbook Dependencies -->
    <script src="~/files/extras/jquery.min.1.7.js"></script>
    <script src="~/files/extras/jquery-ui-1.8.20.custom.min.js"></script>
    <script src="~/files/extras/jquery.mousewheel.min.js"></script>
    <script src="~/files/extras/modernizr.2.5.3.min.js"></script>
    <script src="~/files/lib/hash.js"></script>

    <!-- Flipbook CSS -->
    <link rel="stylesheet" href="~/files/css/docs.css" />
    <link rel="stylesheet" href="~/files/css/jquery.ui.css" />

    <!-- Flipbook Core + App Logic -->
    <script src="~/files/lib/turn.min.js"></script>
    <script src="~/files/js/docs.js"></script>

    <style>
        /* Tắt scroll toàn trang — cuốn sách phải fit gọn trong viewport. */
        html, body {
            overflow: hidden !important;
            height: 100vh !important;
            margin: 0;
        }

        /* Stage chiếm viewport trừ top-nav + sub-nav. */
        /* dsm-nav (fixed 64px) sits above .page-content, so our 100vh container
           would otherwise overflow by 64px and clip the bottom of the book.
           Subtract the nav height here. */
        .safewiki-fullscreen {
            --safewiki-nav-h: 64px;
            --safewiki-subnav-h: 46px;
            --safewiki-top-offset: calc(var(--safewiki-subnav-h) + 4px);
            --safewiki-bottom-offset: 70px; /* chừa chỗ cho 2 nút ‹ › phía dưới */
            position: relative;
            width: 100vw;
            height: calc(100vh - var(--safewiki-nav-h));
            overflow: hidden;
            /* Nền đồng bộ với /Article và /Article/Details (cùng #ffffff) */
            background: #ffffff;
        }

        .safewiki-stage {
            position: absolute;
            top: var(--safewiki-top-offset);
            left: 0;
            right: 0;
            bottom: var(--safewiki-bottom-offset);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* Book uses fixed logical dimensions (turn.js needs explicit pixel
           sizes). We wrap #canvas in a transform-scale so the book always
           fits whichever dimension is tighter. Scale is computed at runtime
           in JS — fallback CSS just keeps the initial natural size. */
        #canvas {
            width: 942px;
            height: 600px;
            margin: 0 auto !important;
            position: relative;
            transform-origin: center center;
            visibility: hidden;
        }

        .sample-docs {
            width: 942px;
            height: 600px;
            margin: 0 !important;
            position: relative;
        }
        .sample-docs .page {
            width: 471px;
            height: 600px;
            background: #fff;
            box-shadow: 0 0 20px rgba(0,0,0,0.2);
        }
        .sample-docs .hard { background-image: url('/files/pics/covers.jpg'); }
        .sample-docs .p2 { background-position: -471px 0; }
        .sample-docs .p28 { background: linear-gradient(to right, #fff 95%, #dadada 100%); }
        .sample-docs .p29 { background-position: -942px 0; }
        .sample-docs .p30 { background-position: -1413px 0; }
        .sample-docs .even .gradient {
            position:absolute; top:0; left:0; width:100%; height:100%;
            background-image:url('/files/pics/right-border.png');
            background-position:right top; background-repeat: repeat-y;
        }
        .sample-docs .odd .gradient {
            position:absolute; top:0; left:0; width:100%; height:100%;
            background-image:url('/files/pics/left-border.png');
            background-position:left top; background-repeat: repeat-y;
        }
        .sample-docs .loader {
            background-image:url('/files/pics/loader.gif');
            width:22px; height:22px; position:absolute; top:45%; left:47%;
        }

        /* Cụm 2 nút ‹ › ở dưới cuốn sách, cạnh nhau. */
        .safewiki-pager {
            position: absolute;
            left: 50%;
            bottom: 16px;
            transform: translateX(-50%);
            display: flex; gap: 16px;
            z-index: 5;
        }
        .safewiki-nav {
            width: 44px; height: 44px;
            border-radius: 50%;
            border: 1px solid rgba(0,0,0,0.08);
            background: #ffffff;
            color: #3a3a3a;
            cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.06);
            transition: color 0.15s ease, background 0.15s ease, transform 0.15s ease;
        }
        .safewiki-nav svg { width: 22px; height: 22px; display: block; }
        .safewiki-nav:hover {
            color: #fff;
            background: var(--art-accent, #00695C);
            border-color: var(--art-accent, #00695C);
            transform: scale(1.06);
        }

        /* Cụm icon góc trên-phải: bật/tắt tiếng + toàn màn hình. */
        .safewiki-tools {
            position: absolute;
            top: 12px; right: 24px;
            display: flex; gap: 6px;
            z-index: 5;
        }
        .safewiki-tool {
            width: 36px; height: 36px;
            border-radius: 8px; border: none;
            background: rgba(255,255,255,0.7);
            color: #3a3a3a;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer;
            transition: background 0.15s ease, color 0.15s ease;
        }
        .safewiki-tool svg { width: 18px; height: 18px; }
        .safewiki-tool:hover { background: var(--art-accent, #00695C); color: #fff; }

        /* Hide the slider bar entirely since we only want the book */
        #slider-bar, .turnjs-slider, #slider { display: none !important; }

        @@media (max-width: 720px) {
            .safewiki-fullscreen { --safewiki-top-offset: 76px; --safewiki-bottom-offset: 64px; }
            #canvas {
                width: min(calc(100vw - 30px), calc((100vh - var(--safewiki-top-offset) - var(--safewiki-bottom-offset)) * 1.548));
            }
            .safewiki-nav { width: 38px; height: 38px; }
            .safewiki-nav svg { width: 18px; height: 18px; }
            .safewiki-tools { right: 10px; }
        }
    </style>

    <script>
        // ── Page-flip sound (synthesized via Web Audio, no external file) ──
        window.SafeWikiFlip = (function () {
            var ctx = null;
            var muted = false;
            function ensure() {
                if (ctx) return ctx;
                try {
                    var AC = window.AudioContext || window.webkitAudioContext;
                    if (!AC) return null;
                    ctx = new AC();
                } catch (e) { return null; }
                return ctx;
            }
            function unlock() {
                var a = ensure(); if (!a) return;
                if (a.state === 'suspended') { try { a.resume(); } catch(e){} }
            }
            function setMuted(m) { muted = !!m; }
            function isMuted() { return muted; }
            // Bắt mọi gesture đầu tiên (không dùng { once: true } để chắc chắn unlock nhiều lần)
            ['click', 'keydown', 'touchstart'].forEach(function (ev) {
                document.addEventListener(ev, unlock, true);
            });

            function play() {
                if (muted) return;
                var a = ensure(); if (!a) return;
                if (a.state === 'suspended') { try { a.resume(); } catch(e){} }
                var now = a.currentTime;
                // Hai lớp noise: (1) "whoosh" dài, (2) "snap" ngắn ở đầu.
                var sampleRate = a.sampleRate;
                var dur = 0.32;
                var buf = a.createBuffer(1, Math.floor(sampleRate * dur), sampleRate);
                var data = buf.getChannelData(0);
                for (var i = 0; i < data.length; i++) {
                    var t = i / data.length;
                    var attack = t < 0.04 ? t / 0.04 : 1;
                    var decay = Math.pow(1 - t, 1.6);
                    var snap = (t < 0.05) ? Math.pow(1 - t / 0.05, 2) * 0.9 : 0;
                    data[i] = (Math.random() * 2 - 1) * (attack * decay * 0.9 + snap);
                }
                var src = a.createBufferSource();
                src.buffer = buf;
                // Dải band-pass hơi rộng + peak quanh 2 kHz cho cảm giác giấy.
                var bp = a.createBiquadFilter();
                bp.type = 'bandpass';
                bp.frequency.value = 2200;
                bp.Q.value = 0.7;
                var gain = a.createGain();
                gain.gain.setValueAtTime(1.6, now);
                src.connect(bp); bp.connect(gain); gain.connect(a.destination);
                src.start(now);
                src.stop(now + dur + 0.05);
            }
            return { play: play, unlock: unlock, setMuted: setMuted, isMuted: isMuted };
        })();

        // Wire tool buttons (sound toggle + fullscreen)
        document.addEventListener('DOMContentLoaded', function () {
            var soundBtn = document.getElementById('safewikiSoundBtn');
            var onIcon  = soundBtn && soundBtn.querySelector('.safewiki-tool__icon--on');
            var offIcon = soundBtn && soundBtn.querySelector('.safewiki-tool__icon--off');
            if (soundBtn) {
                soundBtn.addEventListener('click', function () {
                    var m = !window.SafeWikiFlip.isMuted();
                    window.SafeWikiFlip.setMuted(m);
                    if (onIcon)  onIcon.style.display  = m ? 'none' : '';
                    if (offIcon) offIcon.style.display = m ? '' : 'none';
                });
            }
            var fullBtn = document.getElementById('safewikiFullBtn');
            if (fullBtn) {
                fullBtn.addEventListener('click', function () {
                    var el = document.querySelector('.safewiki-fullscreen') || document.documentElement;
                    if (document.fullscreenElement) { document.exitFullscreen(); }
                    else if (el.requestFullscreen) { el.requestFullscreen(); }
                });
            }
        });

        // Hide the slider element that docs.js may expect, and init turn.js.
        // Slider / hash / mousewheel are kept functional internally so turn.js
        // callbacks don't crash, but the DOM for the slider is hidden via CSS.
        (function () {
            // Inject a hidden slider wrapper so docs.js's $('#slider').slider(...)
            // calls don't NPE.
            if (!document.getElementById('slider-bar')) {
                var wrap = document.createElement('div');
                wrap.id = 'slider-bar';
                wrap.style.display = 'none';
                wrap.innerHTML = '<div id="slider"></div>';
                document.body.appendChild(wrap);
            }

            function initFlipbook() {
                var flipbook = $('.sample-docs');
                if (flipbook.width() == 0 || flipbook.height() == 0) {
                    setTimeout(initFlipbook, 50);
                    return;
                }

                // Slider still initialized (for turn.js internal use), but hidden.
                $("#slider").slider({
                    min: 1,
                    max: 100,
                    slide: function (event, ui) { /* noop — slider is hidden */ },
                    stop: function () {
                        $('.sample-docs').turn('page', Math.max(1, $(this).slider('value') * 2 - 2));
                    }
                });

                // Keyboard arrows
                $(document).keydown(function (e) {
                    if (e.keyCode === 37) { $('.sample-docs').turn('previous'); }
                    else if (e.keyCode === 39) { $('.sample-docs').turn('next'); }
                });

                flipbook.turn({
                    elevation: 50,
                    acceleration: false,
                    gradients: true,
                    autoCenter: true,
                    duration: 1000,
                    pages: 12,
                    when: {
                        turning: function (e, page) {
                            if (window.SafeWikiFlip) { window.SafeWikiFlip.play(); }
                            var book = $(this),
                                currentPage = book.turn('page'),
                                pages = book.turn('pages');
                            if (currentPage > 3 && currentPage < pages - 3) {
                                if (page == 1) {
                                    book.turn('page', 2).turn('stop').turn('page', page);
                                    e.preventDefault(); return;
                                } else if (page == pages) {
                                    book.turn('page', pages - 1).turn('stop').turn('page', page);
                                    e.preventDefault(); return;
                                }
                            }
                            if (window.Hash) { Hash.go('page/' + page).update(); }
                        },
                        turned: function (e, page) {
                            var book = $(this);
                            if (typeof getViewNumber === 'function') {
                                $('#slider').slider('value', getViewNumber(book, page));
                            }
                            book.turn('center');
                        },
                        missing: function (e, pages) {
                            if (typeof addPage === 'function') {
                                for (var i = 0; i < pages.length; i++) addPage(pages[i], $(this));
                            }
                        }
                    }
                }).turn('page', 2);

                if (typeof numberOfViews === 'function') {
                    $('#slider').slider('option', 'max', numberOfViews(flipbook));
                }
                flipbook.addClass('animated');

                $('#canvas').css({ visibility: 'visible' });
            }

            function waitAndInit() {
                if (typeof $ !== 'undefined' && $.fn && $.fn.turn) {
                    initFlipbook();
                } else {
                    setTimeout(waitAndInit, 100);
                }
            }
            waitAndInit();

            // Fit the book to the viewport using CSS transform scale, so turn.js
            // keeps its internal 942×600 pixel math while the user sees a book
            // sized to their screen. Recompute on resize.
            function fitBook() {
                var canvas = document.getElementById('canvas');
                if (!canvas) return;
                var stage = document.querySelector('.safewiki-stage');
                if (!stage) return;
                var availW = stage.clientWidth - 32; // arrows now below, only need a small horizontal margin
                var availH = stage.clientHeight - 12;
                var scale = Math.min(availW / 942, availH / 600, 1.15);
                if (!isFinite(scale) || scale <= 0) scale = 1;
                canvas.style.transform = 'scale(' + scale + ')';
            }
            fitBook();
            var resizeTimer;
            window.addEventListener('resize', function () {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(fitBook, 120);
            });
            // Re-fit after flipbook init paints (delay for turn.js gradient DOM).
            setTimeout(fitBook, 400);
            setTimeout(fitBook, 1200);
        })();
    </script>
}
