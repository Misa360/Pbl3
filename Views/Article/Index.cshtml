                        <button type="button" class="bdn-focus__nav bdn-focus__nav--prev" aria-label="Trước">‹</button>
                        <div class="bdn-focus__viewport">
                            <div class="bdn-focus__deck" id="bdnFocusDeck">
                                @for (int fi = 0; fi < focusList.Count; fi++)
                                {
                                    var f = focusList[fi];
                                    <a class="bdn-focus__card" href="/Article/Details/@f.Id" data-index="@fi">
                                        <div class="bdn-focus__img">
                                            <img src="@(f.ImageUrl ?? "/images/default-article.jpg")" alt="@f.Title" loading="lazy" />
                                        </div>
                                        <div class="bdn-focus__overlay">
                                            <h3 class="bdn-focus__card-title">@f.Title</h3>
