@model List<DaNangSafeMap.Models.Entities.Article>
@{
    var mode = ViewBag.Mode as string ?? "public";
    var currentCat = ViewBag.CurrentCategory as string;
    
    // Set Layout based on mode
    if (mode == "admin") {
        Layout = "_AdminLayout";
        ViewData["Title"] = "Quản lý bài viết - Admin";
    } else {
        Layout = "_Layout";
        if (mode == "home") { ViewData["Title"] = "Tin tức tổng hợp - DaNang SafeMap"; }
        else if (mode == "my") { ViewData["Title"] = "Tin của tôi - DaNang SafeMap"; }
        else { ViewData["Title"] = (currentCat == "an-ninh" ? "An Ninh" : (currentCat == "doi-song" ? "Đời Sống" : "Tin tức")) + " - DaNang SafeMap"; }
    }

    var featured = ViewBag.Featured as List<DaNangSafeMap.Models.Entities.Article> ?? new();
    var allApproved = ViewBag.AllApproved as List<DaNangSafeMap.Models.Entities.Article> ?? new();
    var latest = ViewBag.Latest as List<DaNangSafeMap.Models.Entities.Article> ?? new();
    var mostViewed = ViewBag.MostViewed as List<DaNangSafeMap.Models.Entities.Article> ?? new();
    var categories = ViewBag.Categories as List<DaNangSafeMap.Models.Entities.Category> ?? new();
    var notifications = ViewBag.Notifications as List<DaNangSafeMap.Models.Entities.Notification> ?? new();
    var userId = ViewBag.UserId as int?;
    var role = ViewBag.Role as string;
    
    var mainArticle = featured.FirstOrDefault();
    var sideArticles = featured.Skip(1).Take(3).ToList();
}

<link rel="stylesheet" href="~/css/article.css" />

@if (mode == "admin")
{
    // ══════════════════════════════════════════════
    // GIAO DIỆN ADMIN (Quản lý duyệt bài)
    // ══════════════════════════════════════════════
    <div class="article-container" style="padding-top: 24px; padding-bottom: 48px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h1 style="font-family: var(--art-serif); font-size: 24px; color: var(--art-text); margin: 0;">
                ⚙️ Quản lý tin tức
            </h1>
            <a href="/Article/Create" class="admin-btn approve" style="background: var(--art-primary); text-decoration: none;">+ Viết bài mới</a>
        </div>

        <div class="an-ninh-tabs" style="border-bottom: 2px solid var(--art-primary); margin-bottom: 24px; display: flex; align-items: flex-end;">
            <ul style="list-style: none; padding: 0 0 10px 0; margin: 0; display: flex; gap: 20px;">
                <li id="tab-btn-pending" style="cursor: pointer; font-weight: 600; color: var(--art-accent); border-bottom: 3px solid var(--art-accent); padding-bottom: 6px;" onclick="switchTab('pending')">⏳ Chờ duyệt (@Model.Count)</li>
                <li id="tab-btn-featured" style="color: #666; cursor: pointer; font-weight: 500; padding-bottom: 6px;" onclick="switchTab('featured')">🌟 Quản lý Tin nổi bật (@allApproved.Count bài)</li>
            </ul>
        </div>

        <!-- TAB CHỜ DUYỆT -->
        <div id="tab-pending">
            @if (Model.Any())
            {
                @foreach (var article in Model)
                {
                    <div class="admin-article-card" id="article-card-@article.Id">
                        <div class="admin-article-card__title">@article.Title</div>
                        <div class="admin-article-card__meta">
                            ✍️ @(article.Author?.FullName ?? "Ẩn danh") &nbsp;|&nbsp;
                            📂 @(article.Category?.Name ?? "-") &nbsp;|&nbsp;
                            📅 @article.CreatedAt?.ToString("dd/MM/yyyy HH:mm")
                        </div>
                        @if (!string.IsNullOrEmpty(article.Summary))
                        {
                            <div class="admin-article-card__summary">@article.Summary</div>
                        }
                        @if (!string.IsNullOrEmpty(article.ImageUrl))
                        {
                            <div style="margin-bottom: 12px;">
                                <img src="@article.ImageUrl" alt="" style="max-width: 300px; max-height: 180px; border-radius: 6px; object-fit: cover;" />
                            </div>
                        }
                        <details style="margin-bottom: 12px;">
                            <summary style="cursor: pointer; color: var(--art-accent); font-weight: 600; font-size: 13px;">📄 Xem nội dung đầy đủ</summary>
                            <div style="padding: 12px; background: #f9f9f9; border-radius: 6px; margin-top: 8px; font-size: 14px; line-height: 1.6;">
                                @Html.Raw(article.Content)
                            </div>
                        </details>
                        <div class="admin-article-card__actions">
                            <button class="admin-btn approve" onclick="ArticleApp.approveArticle(@article.Id)">✅ Duyệt bài</button>
                            <button class="admin-btn reject" onclick="ArticleApp.openRejectModal(@article.Id)">❌ Từ chối</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="no-articles">
                    <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                    <p>Không có bài viết nào chờ duyệt 🎉</p>
                </div>
            }
        </div>

        <!-- TAB TIN NỔI BẬT: hiển thị TẤT CẢ bài đã duyệt, cho phép đánh dấu/bỏ nổi bật -->
        <div id="tab-featured" style="display:none;">
            <p style="color: #666; font-size: 13px; margin-bottom: 16px;">💡 Chọn bài viết nào nên xuất hiện ở mục <strong>Tin nổi bật</strong> trên trang chủ. Các bài đang được đánh dấu ⭐ sẽ hiển thị đầu tiên.</p>
            @if (allApproved.Any())
            {
                @foreach (var article in allApproved)
                {
                    var isFeat = article.IsFeatured == true;
                    <div class="admin-article-card" id="feat-card-@article.Id" style="border-left-color: @(isFeat ? "#f39c12" : "#d5d8dc");">
                        <div style="display:flex; justify-content: space-between; align-items:start;">
                            <div>
                                <div class="admin-article-card__title">
                                    @if (isFeat){ <span style="color:#f39c12; margin-right:4px;">⭐</span> }
                                    <a href="/Article/Details/@article.Id" target="_blank" style="color: inherit; text-decoration: none;">@article.Title</a>
                                </div>
                                <div class="admin-article-card__meta" style="margin-top:6px;">
                                    ✍️ @(article.Author?.FullName ?? "Ẩn danh") &nbsp;|&nbsp;
                                    📂 @(article.Category?.Name ?? "-") &nbsp;|&nbsp;
                                    📅 @article.CreatedAt?.ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>
                            <button id="btn-feat-@article.Id"
                                    class="admin-btn @(isFeat ? "reject" : "approve")"
                                    style="white-space:nowrap; flex-shrink:0; margin-left:16px;"
                                    onclick="toggleFeatured(@article.Id, @(isFeat ? "true" : "false"))">
                                @(isFeat ? "❌ Bỏ nổi bật" : "⭐ Đặt nổi bật")
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="no-articles">
                    <p>Chưa có bài viết nào được duyệt.</p>
                </div>
            }
        </div>

    </div>

    <script>
        function switchTab(tabName) {
            document.getElementById('tab-pending').style.display = 'none';
            document.getElementById('tab-featured').style.display = 'none';
            document.getElementById('tab-btn-pending').style.cssText = 'cursor:pointer; font-weight:500; color:#666; padding-bottom:6px;';
            document.getElementById('tab-btn-featured').style.cssText = 'cursor:pointer; font-weight:500; color:#666; padding-bottom:6px;';
            
            var activeTab = document.getElementById('tab-' + tabName);
            var activeBtn = document.getElementById('tab-btn-' + tabName);
            if (activeTab) activeTab.style.display = 'block';
            if (activeBtn) {
                activeBtn.style.color = 'var(--art-accent)';
                activeBtn.style.fontWeight = '700';
                activeBtn.style.borderBottom = '3px solid var(--art-accent)';
            }
        }

        function toggleFeatured(id, currentlyFeatured) {
            var isFeat = currentlyFeatured === true || currentlyFeatured === 'true';
            fetch('/Article/ToggleFeatured/' + id, { method: 'POST' })
                .then(res => {
                    if (res.ok) {
                        var card = document.getElementById('feat-card-' + id);
                        var btn = document.getElementById('btn-feat-' + id);
                        if (isFeat) {
                            // Was featured, now unfeatured
                            card.style.borderLeftColor = '#d5d8dc';
                            btn.textContent = '⭐ Đặt nổi bật';
                            btn.className = 'admin-btn approve';
                            btn.setAttribute('onclick', 'toggleFeatured(' + id + ', false)');
                            // Remove star from title
                            var star = card.querySelector('.feat-star');
                            if (star) star.remove();
                        } else {
                            // Was not featured, now is
                            card.style.borderLeftColor = '#f39c12';
                            btn.textContent = '❌ Bỏ nổi bật';
                            btn.className = 'admin-btn reject';
                            btn.setAttribute('onclick', 'toggleFeatured(' + id + ', true)');
                        }
                    }
                });
        }
    </script>

    <!-- REJECT MODAL -->
    <div class="reject-modal" id="reject-modal">
        <div class="reject-modal__inner">
            <h3>❌ Từ chối bài viết</h3>
            <p style="font-size: 14px; color: var(--art-text-muted); margin-bottom: 12px;">
                Vui lòng nhập lý do từ chối để thông báo cho tác giả:
            </p>
            <textarea id="reject-reason" placeholder="Lý do từ chối bài viết..."></textarea>
            <div class="reject-modal__actions">
                <button class="admin-btn" style="background: var(--art-border); color: var(--art-text);" onclick="ArticleApp.closeRejectModal()">Hủy</button>
                <button class="admin-btn reject" onclick="ArticleApp.submitReject()">Xác nhận từ chối</button>
            </div>
        </div>
    </div>
}
else if (mode == "my")
{
    // ══════════════════════════════════════════════
    // GIAO DIỆN MY ARTICLES
    // ══════════════════════════════════════════════
    <div class="article-page-wrapper">
        @await Html.PartialAsync("_ArticleSubNav")
        <div class="article-container" style="padding-top: 40px; padding-bottom: 80px;">
            <div class="my-articles-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                <h1 style="font-family: var(--art-serif); font-size: 28px; color: var(--art-text);">📝 Bài viết của tôi</h1>
                <a href="/Article/Create" class="art-btn art-btn-primary">✍️ Viết bài mới</a>
            </div>

            @if (notifications.Any())
            {
                var unread = notifications.Where(n => n.IsRead == false).ToList();
                <div style="margin-bottom: 28px;">
                    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
                        <span style="font-size: 16px; font-weight: 700; color: var(--art-text);">🔔 Thông báo</span>
                        @if (unread.Any())
                        {
                            <span style="background: var(--art-orange); color: #fff; font-size: 11px; font-weight: 700; border-radius: 12px; padding: 2px 8px;">@unread.Count mới</span>
                        }
                    </div>
                    @foreach (var notif in notifications.Take(5))
                    {
                        var notifBg = notif.IsRead == false ? "#fef9f0" : "#f9f9f9";
                        var notifBorder = notif.Type == "APPROVED" ? "#27ae60" : (notif.Type == "REJECTED" ? "#e74c3c" : "#e67e22");
                        <div style="background: @notifBg; border-left: 4px solid @notifBorder; border-radius: 6px; padding: 12px 16px; margin-bottom: 8px;">
                            <div style="font-weight: 700; font-size: 14px; color: var(--art-text); margin-bottom: 4px;">@notif.Title</div>
                            <div style="font-size: 13px; color: var(--art-text-secondary);">@notif.Content</div>
                            <div style="font-size: 11px; color: var(--art-text-muted); margin-top: 6px;">🕒 @notif.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                    }
                </div>
            }

            @if (Model != null && Model.Any())
            {
                <div class="my-articles-list">
                    @foreach (var article in Model)
                    {
                        var statusColor = article.Status == 1 ? "orange" : (article.Status == 2 ? "green" : "red");
                        var statusText = article.Status == 1 ? "Chờ duyệt" : (article.Status == 2 ? "Đã duyệt" : "Từ chối");
                        
                        <div class="my-article-card" style="border: 1px solid #eee; border-radius: 8px; padding: 16px; margin-bottom: 16px; display: flex; gap: 16px; align-items: start;">
                            @if (!string.IsNullOrEmpty(article.ImageUrl))
                            {
                                <img src="@article.ImageUrl" alt="@article.Title" style="width: 120px; height: 80px; object-fit: cover; border-radius: 4px;" />
                            }
                            <div style="flex: 1;">
                                <h3 style="margin: 0 0 8px 0; font-size: 18px;">
                                    <a href="/Article/Details/@article.Id" style="color: var(--art-text); text-decoration: none;">@article.Title</a>
                                </h3>
                                <div style="font-size: 13px; color: var(--art-text-muted); margin-bottom: 8px;">
                                    <span>📅 @article.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                                    <span style="margin: 0 8px;">|</span>
                                    <span>👁️ @(article.ViewCount ?? 0) view</span>
                                </div>
                                <span style="display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 600; color: #fff; background-color: @statusColor;">
                                    @statusText
                                </span>
                                @if (article.Status == 3 && !string.IsNullOrEmpty(article.RejectReason))
                                {
                                    <div style="margin-top: 8px; font-size: 13px; color: red; background: #fff0f0; padding: 8px; border-radius: 4px; border-left: 3px solid red;">
                                        <strong>Lý do từ chối:</strong> @article.RejectReason
                                    </div>
                                }
                            </div>
                            <div>
                                <!-- Users không thể xóa bài - admin quản lý -->
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="no-articles" style="text-align: center; padding: 60px 0; background: #fdfdfd; border-radius: 8px; border: 1px dashed #ddd;">
                    <p style="color: var(--art-text-muted); margin-bottom: 16px;">Bạn chưa đăng bài viết nào.</p>
                    <a href="/Article/Create" class="art-btn art-btn-primary">Viết bài đầu tiên</a>
                </div>
            }
        </div>
    </div>
}
else if (mode == "public" || mode == "home")
{
    // ══════════════════════════════════════════════
    // GIAO DIỆN PUBLIC — lấy cảm hứng từ baodanang.vn
    //   • Trang chủ /Article                   → nav chuyên mục + top 3 cột + block riêng từng chuyên mục
    //   • /Article?categorySlug=an-ninh/doi-song → nav + header đỏ + 1 big + grid nhỏ (fit màn hình)
    // ══════════════════════════════════════════════
    var latestByCat = ViewBag.LatestByCat as Dictionary<string, List<DaNangSafeMap.Models.Entities.Article>>
                      ?? new Dictionary<string, List<DaNangSafeMap.Models.Entities.Article>>();
    var isHome = string.IsNullOrEmpty(currentCat);

    // Tin nóng ticker (global/category)
    var tickerItems = latest.Take(6).Concat(featured.Skip(1)).Take(8).ToList();

    // Helper: "x giờ trước" theo tiếng Việt
    Func<DateTime?, string> humanTime = (dt) =>
    {
        if (dt == null) return "";
        var diff = DateTime.Now - dt.Value;
        if (diff.TotalMinutes < 1) return "vừa xong";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} phút trước";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} giờ trước";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} ngày trước";
        return dt.Value.ToString("dd/MM/yyyy");
    };

    // Giả sub-cats cho block trang chủ (hiển thị decorative, click về chuyên mục gốc)
    var subCatsMap = new Dictionary<string, string[]>
    {
        ["an-ninh"]  = new[] { "Tin mới", "Cảnh báo", "ATGT", "Vụ việc", "Phòng chống" },
        ["doi-song"] = new[] { "Đô thị", "Môi trường", "Cộng đồng", "Văn hoá" }
    };

    <link rel="stylesheet" href="~/css/article-news.css" />

    <div class="bdn-page">
        @await Html.PartialAsync("_ArticleSubNav")

        @* Thanh chuyên mục đỏ đỏ kiểu baodanang — luôn hiển thị *@
        <nav class="bdn-catnav" aria-label="Chuyên mục">
            <div class="bdn-catnav__inner">
                <a class="bdn-catnav__home @(isHome ? "is-active" : "")" href="/Article" aria-label="Trang chủ tin tức">🏠</a>
                @foreach (var c in categories)
                {
                    <a class="bdn-catnav__item @(currentCat == c.Slug ? "is-active" : "")"
                       href="/Article?categorySlug=@c.Slug">@c.Name</a>
                }
                <a class="bdn-catnav__item" href="/Article/SafeWiki">SafeWiki</a>
                <a class="bdn-catnav__item" href="/Article/Hotline">Hotline</a>
            </div>
        </nav>

        @if (tickerItems.Any())
        {
            <div class="bdn-ticker" role="region" aria-label="Tin nóng">
                <div class="bdn-ticker__label">🔴 TIN NÓNG</div>
                <div class="bdn-ticker__viewport">
                    <div class="bdn-ticker__track">
                        @foreach (var t in tickerItems)
                        {
                            <a class="bdn-ticker__item" href="/Article/Details/@t.Id">@t.Title</a>
                            <span class="bdn-ticker__sep">•</span>
                        }
                        @foreach (var t in tickerItems)
                        {
                            <a class="bdn-ticker__item" href="/Article/Details/@t.Id">@t.Title</a>
                            <span class="bdn-ticker__sep">•</span>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="bdn-container">

        @if (isHome)
        {
            // ══ TRANG CHỦ /Article ══
            var topHero = featured.FirstOrDefault() ?? latest.FirstOrDefault();
            var shortList = latest.Where(x => x != topHero).Take(5).ToList();
            var topSide = featured.Where(x => x != topHero).Take(2).ToList();
            if (topSide.Count < 2)
            {
                foreach (var a in latest.Where(x => x != topHero && !topSide.Contains(x)))
                {
                    topSide.Add(a);
                    if (topSide.Count >= 2) break;
                }
            }

            <section class="bdn-top">
                <aside class="bdn-top__side">
                    @foreach (var it in shortList)
                    {
                        <a class="bdn-brief" href="/Article/Details/@it.Id">
                            <span class="bdn-brief__time">@humanTime(it.CreatedAt)</span>
                            <h3 class="bdn-brief__title">@it.Title</h3>
                        </a>
                    }
                </aside>

                @if (topHero != null)
                {
                    <article class="bdn-top__hero">
                        <a href="/Article/Details/@topHero.Id" class="bdn-top__hero-img">
                            <img src="@(topHero.ImageUrl ?? "/images/default-article.jpg")" alt="@topHero.Title" />
                        </a>
                        <h2 class="bdn-top__hero-title">
                            <a href="/Article/Details/@topHero.Id">@topHero.Title</a>
                        </h2>
                        @if (!string.IsNullOrEmpty(topHero.Summary))
                        {
                            <p class="bdn-top__hero-lead">
                                <span class="bdn-lead-dno">ĐNO</span> — @topHero.Summary
                            </p>
                        }
                    </article>
                }

                <aside class="bdn-top__right">
                    @foreach (var s in topSide)
                    {
                        <a class="bdn-sidecard" href="/Article/Details/@s.Id">
                            <div class="bdn-sidecard__img">
                                <img src="@(s.ImageUrl ?? "/images/default-article.jpg")" alt="@s.Title" />
                            </div>
                            <h3 class="bdn-sidecard__title">@s.Title</h3>
                        </a>
                    }
                    @if (mostViewed.Any())
                    {
                        <div class="bdn-sidecard bdn-sidecard--popular">
                            <h4 class="bdn-sidecard__pop-head">🔥 Đọc nhiều nhất</h4>
                            <ol class="bdn-sidecard__pop-list">
                                @for (int i = 0; i < Math.Min(5, mostViewed.Count); i++)
                                {
                                    <li><a href="/Article/Details/@mostViewed[i].Id">@mostViewed[i].Title</a></li>
                                }
                            </ol>
                        </div>
                    }
                </aside>
            </section>

            @* Mỗi chuyên mục một block "header đỏ + 1 bài lớn bên trái + 4-6 bài nhỏ bên phải" *@
            @foreach (var c in categories)
            {
                if (string.IsNullOrEmpty(c.Slug)) continue;
                var items = latestByCat.GetValueOrDefault(c.Slug) ?? new List<DaNangSafeMap.Models.Entities.Article>();
                if (!items.Any()) continue;
                var big = items.First();
                var rest = items.Skip(1).Take(6).ToList();
                var subCats = subCatsMap.ContainsKey(c.Slug) ? subCatsMap[c.Slug] : Array.Empty<string>();

                <section class="bdn-block">
                    <header class="bdn-block__head">
                        <h2 class="bdn-block__title">
                            <span class="bdn-block__rule"></span>
                            <a href="/Article?categorySlug=@c.Slug">@c.Name.ToUpper()</a>
                            <span class="bdn-block__rule"></span>
                        </h2>
                        @if (subCats.Any())
                        {
                            <div class="bdn-block__subs">
                                @for (int i = 0; i < subCats.Length; i++)
                                {
                                    <a href="/Article?categorySlug=@c.Slug">@subCats[i]</a>
                                    if (i < subCats.Length - 1)
                                    {
                                        <span class="bdn-block__sub-sep">|</span>
                                    }
                                }
                            </div>
                        }
                    </header>

                    <div class="bdn-block__grid">
                        <a class="bdn-big" href="/Article/Details/@big.Id">
                            <div class="bdn-big__img">
                                <img src="@(big.ImageUrl ?? "/images/default-article.jpg")" alt="@big.Title" />
                            </div>
                            <h3 class="bdn-big__title">@big.Title</h3>
                            @if (!string.IsNullOrEmpty(big.Summary))
                            {
                                <p class="bdn-big__lead"><span class="bdn-lead-dno">ĐNO</span> — @big.Summary</p>
                            }
                        </a>

                        <div class="bdn-minis">
                            @foreach (var it in rest)
                            {
                                <a class="bdn-mini" href="/Article/Details/@it.Id">
                                    <h4 class="bdn-mini__title">@it.Title</h4>
                                    <div class="bdn-mini__img">
                                        <img src="@(it.ImageUrl ?? "/images/default-article.jpg")" alt="@it.Title" />
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                </section>
            }
        }
        else
        {
            // ══ TRANG CHUYÊN MỤC /Article?categorySlug=... ══
            //   Format giống baodanang.vn/van-hoa-van-nghe — fit viewport, không cần scroll ngang.
            var catObj = categories.FirstOrDefault(x => x.Slug == currentCat);
            var catName = catObj?.Name ?? currentCat;
            var bigCat = latest.FirstOrDefault();
            var restCat = latest.Skip(1).Take(12).ToList();
            var subCatsCat = subCatsMap.ContainsKey(currentCat ?? "") ? subCatsMap[currentCat!] : Array.Empty<string>();

            <section class="bdn-block bdn-block--page">
                <header class="bdn-block__head">
                    <h1 class="bdn-block__title">
                        <span class="bdn-block__rule"></span>
                        @(catName?.ToUpper())
                        <span class="bdn-block__rule"></span>
                    </h1>
                    @if (subCatsCat.Any())
                    {
                        <div class="bdn-block__subs">
                            @for (int i = 0; i < subCatsCat.Length; i++)
                            {
                                <a href="/Article?categorySlug=@currentCat">@subCatsCat[i]</a>
                                if (i < subCatsCat.Length - 1)
                                {
                                    <span class="bdn-block__sub-sep">|</span>
                                }
                            }
                        </div>
                    }
                </header>

                @if (bigCat != null)
                {
                    <div class="bdn-block__grid">
                        <a class="bdn-big" href="/Article/Details/@bigCat.Id">
                            <div class="bdn-big__img">
                                <img src="@(bigCat.ImageUrl ?? "/images/default-article.jpg")" alt="@bigCat.Title" />
                            </div>
                            <h3 class="bdn-big__title">@bigCat.Title</h3>
                            @if (!string.IsNullOrEmpty(bigCat.Summary))
                            {
                                <p class="bdn-big__lead"><span class="bdn-lead-dno">ĐNO</span> — @bigCat.Summary</p>
                            }
                        </a>

                        <div class="bdn-minis bdn-minis--page">
                            @foreach (var it in restCat.Take(6))
                            {
                                <a class="bdn-mini" href="/Article/Details/@it.Id">
                                    <h4 class="bdn-mini__title">@it.Title</h4>
                                    <div class="bdn-mini__img">
                                        <img src="@(it.ImageUrl ?? "/images/default-article.jpg")" alt="@it.Title" />
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (restCat.Count > 6)
                {
                    <div class="bdn-block__extra">
                        @foreach (var it in restCat.Skip(6))
                        {
                            <a class="bdn-mini bdn-mini--wide" href="/Article/Details/@it.Id">
                                <h4 class="bdn-mini__title">@it.Title</h4>
                                <div class="bdn-mini__img">
                                    <img src="@(it.ImageUrl ?? "/images/default-article.jpg")" alt="@it.Title" />
                                </div>
                            </a>
                        }
                    </div>
                }

                @if (!latest.Any())
                {
                    <div class="bdn-empty">
                        <p>Chưa có bài viết nào trong chuyên mục này.</p>
                    </div>
                }
            </section>
        }

        </div>@* /bdn-container *@

        @if (userId != null && role != "Admin")
        {
            <a href="/Article/Create" class="art-fab" title="Viết bài mới">
                <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            </a>
        }
    </div>

}

@section Scripts {
    <script src="~/js/article.js"></script>
}
