    <div class="art-footer__bottom">
        <span>© 2026 DaNang SafeMap. Bảo lưu mọi quyền.</span>
        <a href="#">Chính sách bảo mật</a>
    </div>
</footer>


<style>
    .container-main { padding: 0 5cm; margin-top: 30px; }
    
    .btn-floating-publish {
        position: fixed; bottom: 30px; right: 30px; z-index: 1000;
        background-color: #0d6efd; color: white; padding: 15px 25px;
        border-radius: 50px; text-decoration: none; font-weight: bold;
        display: flex; align-items: center; gap: 10px;
        box-shadow: 0 4px 15px rgba(13, 110, 253, 0.4);
        transition: all 0.3s ease;
    }
    .btn-floating-publish:hover { background-color: #0b5ed7; transform: translateY(-3px); }

    .page-brand { font-weight: 900; letter-spacing: -1px; }
    .section-title {
        font-weight: 800; font-size: 1.1rem;
        border-left: 5px solid #0d6efd; padding-left: 10px;
        margin-bottom: 25px; color: #333;
    }

    .spotlight-card { height: 500px; border-radius: 15px; overflow: hidden; position: relative; }
    .spotlight-card img { width: 100%; height: 100%; object-fit: cover; }
    .spotlight-overlay { position: absolute; bottom: 0; padding: 40px; background: linear-gradient(transparent, rgba(0,0,0,0.9)); color: white; width: 100%; }

    .fd-item { padding: 0 0.25cm; } /* Khoảng cách 0.5cm tổng cộng */
    .fd-thumb { height: 180px; border-radius: 10px; overflow: hidden; margin-bottom: 10px; }
    .fd-thumb img { width: 100%; height: 100%; object-fit: cover; transition: 0.4s; }
    .fd-title { font-weight: 700; font-size: 0.95rem; line-height: 1.4; }

    .main-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 50px; }
    .rank-num { font-size: 1.2rem; font-weight: 900; color: #0d6efd; opacity: 0.5; }

    @@media (max-width: 1400px) { .container-main { padding: 0 20px; } }

    /* ── City Banner ─────────────────────────────── */
    .city-banner-link { display: block; text-decoration: none; margin-top: 60px; }
    .city-banner {
        position: relative;
        height: 280px;
        overflow: hidden;
    }
    .city-banner img {
        width: 100%; height: 100%;
        object-fit: cover;
        display: block;
    }
    .city-banner-tint {
        position: absolute; inset: 0;
        background: rgba(30, 110, 80, 0.62);
    }

    /* ── Footer ──────────────────────────────────── */
    .art-footer {
        background: #111827;
        color: #9ca3af;
        font-size: 0.88rem;
    }
    .art-footer__inner {
        display: grid;
        grid-template-columns: 1.8fr 1fr 1fr 1fr;
        gap: 48px;
        max-width: 1280px;
        margin: 0 auto;
        padding: 56px 32px 40px;
    }
    /* Brand column */
    .art-footer__brand { }
    .art-footer__logo {
        width: 42px; height: 42px;
        background: #16a34a;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 14px;
    }
    .art-footer__logo svg {
        width: 22px; height: 22px;
        stroke: #fff; fill: none;
        stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
    }
    .art-footer__brand > span {
        display: block;
        font-size: 1rem; font-weight: 700;
        color: #fff; margin-bottom: 10px;
    }
    .art-footer__brand p { line-height: 1.65; margin-bottom: 20px; }
    .art-footer__socials { display: flex; gap: 10px; }
    .art-footer__socials a {
        width: 36px; height: 36px; border-radius: 8px;
        background: #1f2937;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.2s;
    }
    .art-footer__socials a:hover { background: #16a34a; }
    .art-footer__socials svg {
        width: 16px; height: 16px;
        stroke: #9ca3af; fill: none;
        stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
        transition: stroke 0.2s;
    }
    .art-footer__socials a:hover svg { stroke: #fff; }
    /* Nav columns */
    .art-footer__col h4 {
        color: #fff;
        font-size: 0.85rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .08em;
        margin-bottom: 16px;
    }
    .art-footer__col ul { list-style: none; padding: 0; margin: 0; }
    .art-footer__col li {
        display: flex; align-items: center; gap: 8px;
        margin-bottom: 10px;
    }
    .art-footer__col li a {
        color: #9ca3af; text-decoration: none;
        transition: color 0.2s;
    }
    .art-footer__col li a:hover { color: #fff; }
    .art-footer__col li svg {
        width: 14px; height: 14px; flex-shrink: 0;
        stroke: #16a34a; fill: none;
        stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
    }
    /* Bottom bar */
    .art-footer__bottom {
        border-top: 1px solid #1f2937;
        display: flex; justify-content: center; align-items: center; gap: 20px;
        padding: 18px 32px;
        font-size: 0.82rem;
        color: #6b7280;
    }
    .art-footer__bottom a { color: #16a34a; text-decoration: none; }
    .art-footer__bottom a:hover { text-decoration: underline; }

    @@media (max-width: 900px) {
        .art-footer__inner { grid-template-columns: 1fr 1fr; gap: 32px; }
        .city-banner { height: 200px; }
    }
    @@media (max-width: 600px) {
        .art-footer__inner { grid-template-columns: 1fr; }
    }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>

    <script>
        $(document).ready(function(){
            $('.featured-slider').slick({
                infinite: true,
                slidesToShow: 4,
                slidesToScroll: 1,
                autoplay: true,
                autoplaySpeed: 3000,
                arrows: true,
                dots: false,
                responsive: [
                    { breakpoint: 1024, settings: { slidesToShow: 2 } },
                    { breakpoint: 600, settings: { slidesToShow: 1 } }
                ]
            });
        });

        // Infinite Scroll
        let page = 2;
        let isThrottled = false;
        let hasMore = true;
        $(window).scroll(function () {
            if ($(window).scrollTop() + $(window).height() > $(document).height() - 600) {
                if (!isThrottled && hasMore) {
                    isThrottled = true;
                    $("#loader").show();
            
                    $.get(`/Article/GetMoreArticles?page=${page}`, function (data) {
                        if (data.trim().length === 0) {
                            hasMore = false;
                            $("#loader").hide();
                        } else {
                            $("#newFeedContainer").append(data);
                            page++;
                            isThrottled = false;
                            $("#loader").hide();
                        }
                    }).fail(function() {
                        isThrottled = false;
                        $("#loader").hide();
                    });
                }
            }
        });
    </script>
}