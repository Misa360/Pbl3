@model IEnumerable<DaNangSafeMap.Models.Entities.Article>

@{
    ViewData["Title"] = "Trang tin tức Đà Nẵng";

    // 1. Spotlight (Tin to nhất)
    var spotlight = Model
        .Where(x => x.IsFeatured && x.Status == 2)
        .OrderByDescending(x => x.CreatedAt)
        .FirstOrDefault();

    // 2. Slider Tin Nổi Bật 
    var featuredSlides = Model
        .Where(x => x.IsFeatured && x.Status == 2 && (spotlight == null || x.Id != spotlight.Id))
        .Take(10);

    // 3. Trending & New Feed
    var trending = Model.Where(x => x.Status == 2).OrderByDescending(x => x.CreatedAt).Take(5);
    var initialNewFeed = Model.Where(x => x.Status == 2).OrderByDescending(x => x.CreatedAt).Take(10);
    
    // Tiêu điểm năm 2026 (Theo yêu cầu của bạn)
    var spotlightYear = Model.Where(x => x.IsFeatured && x.CreatedAt.Year == 2026).Take(5);
}

<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css"/>
<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css"/>

<a asp-controller="Article" asp-action="Create" class="btn-floating-publish">
    <i class="bi bi-pencil-square"></i>
    <span>+ ĐĂNG TIN</span>
</a>

<div class="container-main">

    <div class="action-bar mb-4">
        <h2 class="page-brand">DANANG <span class="text-primary">SAFE MAP</span></h2>
    </div>

    @if (spotlight != null)
    {
        <div class="spotlight-section mb-5">
            <a asp-controller="Article" asp-action="Details" asp-route-id="@spotlight.Id" class="text-decoration-none">
                <div class="spotlight-card">
                     <img src="@spotlight.ImageUrl" alt="@spotlight.Title" onerror="this.src='/images/default.jpg'" />
                    <div class="spotlight-overlay">
                        <span class="badge bg-danger mb-2">HOT NEWS</span>
                        <h1>@spotlight.Title</h1>
                        <p>@spotlight.Summary</p>
                        <div class="small"><i class="bi bi-eye"></i> @spotlight.ViewCount lượt xem</div>
                    </div>
                </div>
            </a>
        </div>
    }

    <div class="featured-slider-wrapper mb-5">
        <h3 class="section-title">TIN NỔI BẬT</h3>
        <div class="featured-slider">
            @foreach (var item in featuredSlides)
            {
                <div class="fd-item">
                    <a asp-controller="Article" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">
                        <div class="fd-thumb">
                           <img src="@item.ImageUrl" alt="@item.Title" onerror="this.src='/images/default.jpg'" />
                        </div>
                        <p class="fd-title">@item.Title</p>
                        <small class="text-muted"><i class="bi bi-eye"></i> @item.ViewCount</small>
                    </a>
               </div>
            }
        </div>
    </div>

    <div class="main-grid">
        <div class="newfeed-section">
            <h3 class="section-title">DÒNG TIN MỚI</h3>
            <div id="newFeedContainer">
                <partial name="_ArticleSection" model="initialNewFeed" />
            </div>
            <div id="loader" class="text-center my-4" style="display:none;">
                <div class="spinner-border text-primary"></div>
            </div>
        </div>

        <div class="trending-section">
            <div class="sticky-top" style="top: 100px;">
                <h3 class="section-title border-danger">TIÊU ĐIỂM 2026</h3>
                @{ int rank = 1; }
                @foreach (var item in spotlightYear)
                {
                    <div class="trending-row d-flex mb-3">
                        <span class="rank-num">#@rank</span>
                        <a asp-controller="Article" asp-action="Details" asp-route-id="@item.Id" class="text-dark fw-bold text-decoration-none ms-2">@item.Title</a>
                    </div>
                    rank++;
                }
            </div>
        </div>
    </div>
</div>

<!-- ── CITY BANNER (chỉ ảnh, không chữ, bấm → trang bản đồ) ── -->
<a asp-controller="Map" asp-action="Index" class="city-banner-link">
    <div class="city-banner">
        <img src="https://images.unsplash.com/photo-1583417319070-4a69db38a482?w=1600&q=80"
             alt="Đà Nẵng"
             onerror="this.src='https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1600&q=80'" />
        <div class="city-banner-tint"></div>
    </div>
</a>

<!-- ── FOOTER ── -->
