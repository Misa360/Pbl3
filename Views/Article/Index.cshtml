                            </div>
                        </div>
                        <button type="button" class="bdn-focus__nav bdn-focus__nav--next" aria-label="Sau">›</button>
                    </div>
                </section>
            }

            @* ═══ AN TOÀN KHÔNG GIAN MẠNG — laptop mockup + 2 side cards ═══ *@
            <section class="bdn-aware" aria-label="An toàn không gian mạng">
                <header class="bdn-aware__head">
