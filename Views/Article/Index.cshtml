            <section class="bdn-cat">
                <header class="bdn-cat__head">
                    <h1 class="bdn-cat__title">@catName.ToUpper()</h1>
                    <nav class="bdn-cat__crumb" aria-label="Breadcrumb">
                        <a href="/Article">Trang chủ</a> / <span>@catName</span>
                    </nav>
                </header>

                @if (heroBig != null)
                {
                    <div class="bdn-cat__top">
                        <a class="bdn-cat__big" href="/Article/Details/@heroBig.Id">
                            <div class="bdn-cat__big-img">
                                <img src="@(heroBig.ImageUrl ?? "/images/default-article.jpg")" alt="@heroBig.Title" />
                            </div>
                            <h3 class="bdn-cat__big-title">@heroBig.Title</h3>
                        </a>
                        <div class="bdn-cat__mini4">
                            @foreach (var it in topMinis)
                            {
                                <a class="bdn-cat__mini" href="/Article/Details/@it.Id">
                                    <div class="bdn-cat__mini-img">
                                        <img src="@(it.ImageUrl ?? "/images/default-article.jpg")" alt="@it.Title" />
                                    </div>
                                    <h4 class="bdn-cat__mini-title">@it.Title</h4>
                                </a>
                            }
                        </div>
                    </div>
                }

                <div class="bdn-cat__grid">
                    <div class="bdn-cat__list">
                        @foreach (var it in listItems)
                        {
                            <article class="bdn-cat__row">
                                <a class="bdn-cat__row-img" href="/Article/Details/@it.Id">
                                    <img src="@(it.ImageUrl ?? "/images/default-article.jpg")" alt="@it.Title" />
                                </a>
                                <div class="bdn-cat__row-body">
                                    <h3><a href="/Article/Details/@it.Id">@it.Title</a></h3>
                                    <div class="bdn-cat__row-meta">
                                        <span class="bdn-cat__row-cat">@catName</span>
                                        <span class="bdn-cat__row-date">@it.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(it.Summary))
                                    {
                                        <p class="bdn-cat__row-sum">@it.Summary</p>
                                    }
                                </div>
                            </article>
                        }
                        @if (!listItems.Any() && heroBig == null)
                        {
                            <div class="bdn-empty" style="padding:40px 0;color:var(--bdn-muted);text-align:center;">
                                Chưa có bài viết nào trong chuyên mục này.
                            </div>
                        }
                    </div>

                    <aside class="bdn-cat__aside">
                        <div class="bdn-cat__tabs" role="tablist">
                            <button class="bdn-cat__tab is-active" data-target="pop" type="button">Đọc nhiều</button>
                            <button class="bdn-cat__tab" data-target="new" type="button">Tin mới</button>
                        </div>
                        <ol class="bdn-cat__rank" data-tab="pop">
                            @for (int i = 0; i < popItems.Count; i++)
                            {
                                var p = popItems[i];
                                <li>
                                    <div class="bdn-cat__rank-num">@(i + 1)</div>
                                    <div class="bdn-cat__rank-img">
                                        <img src="@(p.ImageUrl ?? "/images/default-article.jpg")" alt="@p.Title" />
                                    </div>
                                    <div class="bdn-cat__rank-body">
                                        <a href="/Article/Details/@p.Id">@p.Title</a>
                                    </div>
                                </li>
                            }
                        </ol>
                        <ol class="bdn-cat__rank is-hidden" data-tab="new">
                            @for (int i = 0; i < newItems.Count; i++)
                            {
                                var p = newItems[i];
                                <li>
                                    <div class="bdn-cat__rank-num">@(i + 1)</div>
                                    <div class="bdn-cat__rank-img">
                                        <img src="@(p.ImageUrl ?? "/images/default-article.jpg")" alt="@p.Title" />
                                    </div>
                                    <div class="bdn-cat__rank-body">
                                        <a href="/Article/Details/@p.Id">@p.Title</a>
                                    </div>
                                </li>
                            }
                        </ol>
                    </aside>
                </div>
            </section>
        }

        </div>@* /bdn-container *@

        @if (userId != null && role != "Admin")
        {
            <a href="/Article/Create" class="art-fab" title="Viết bài mới">
                <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            </a>
        }

        @await Html.PartialAsync("_SiteFooter")
    </div>

}

@section Scripts {
    <script src="~/js/article.js"></script>
    <script>
        // ── Tiêu điểm: slide ngang, card cùng kích cỡ, bước 1 bài / 4s ──
        (function(){
            var stage = document.getElementById('bdnFocusStage');
            var deck  = document.getElementById('bdnFocusDeck');
            if (!stage || !deck) return;
            var cards = Array.prototype.slice.call(deck.querySelectorAll('.bdn-focus__card'));
            var n = cards.length;
            if (n === 0) return;

            var viewport = stage.querySelector('.bdn-focus__viewport');
            var current = 0;
            var timer = null;
            var interval = 4000;

            function cardW(){
                var c = cards[0];
                return c ? c.getBoundingClientRect().width : 0;
            }
            function gapW(){
                var cs = getComputedStyle(deck);
                return parseFloat(cs.columnGap || cs.gap) || 0;
            }
            function step(){ return cardW() + gapW(); }
            function render(){
                // Đo không gian khả dụng tự nhiên: reset width trước rồi đọc clientWidth.
                viewport.style.width = '';
                var avail = viewport.clientWidth;
                var s = step();
                if (s <= 0) return;
                var v = Math.max(1, Math.floor((avail + gapW()) / s));
                v = Math.min(n, v);
                var width = v * cardW() + Math.max(0, v - 1) * gapW();
                // Co viewport cho khớp đúng số card hiển thị — không còn thừa mép phải.
                viewport.style.width = width + 'px';

                var maxStart = Math.max(0, n - v);
                if (current < 0) current = maxStart;
                if (current > maxStart) current = 0;
                deck.style.transform = 'translateX(' + (-current * step()) + 'px)';
            }
            function go(delta){ current += delta; render(); }
            function start(){ if (timer) return; timer = setInterval(function(){ go(1); }, interval); }
            function stop(){ if (timer){ clearInterval(timer); timer = null; } }

            stage.querySelector('.bdn-focus__nav--prev').addEventListener('click', function(){ go(-1); stop(); start(); });
            stage.querySelector('.bdn-focus__nav--next').addEventListener('click', function(){ go( 1); stop(); start(); });
            stage.addEventListener('mouseenter', stop);
            stage.addEventListener('mouseleave', start);
            window.addEventListener('resize', render);

            render();
            start();
        })();

        // ── An toàn không gian mạng — laptop mockup carousel (slide ngang) ──
        (function(){
            var rig    = document.getElementById('bdnAwareRig');
            var store  = document.getElementById('bdnAwareStore');
            var track  = document.getElementById('bdnAwareTrack');
            var dotsEl = document.getElementById('bdnAwareDots');
            var btnPrev = document.getElementById('bdnAwareBtnPrev');
            var btnNext = document.getElementById('bdnAwareBtnNext');
            var prevSide = document.getElementById('bdnAwarePrev');
            var nextSide = document.getElementById('bdnAwareNext');
            if (!rig || !store || !track) return;

            var sources = Array.prototype.slice.call(store.querySelectorAll(':scope > div[data-title]'));
            var items = sources.map(function(d){
                return {
                    title: d.getAttribute('data-title') || '',
                    text:  d.getAttribute('data-text')  || '',
                    svg:   d.innerHTML.trim()
                };
            });
            var n = items.length;
            if (!n) return;

            // Build slides
            track.innerHTML = items.map(function(it){
                return '<div class="bdn-aware__slide">' +
                            '<div class="bdn-aware__icon" aria-hidden="true">' + it.svg + '</div>' +
                            '<div class="bdn-aware__panel">' +
                                '<h3 class="bdn-aware__panel-title">' + it.title + '</h3>' +
                                '<p class="bdn-aware__panel-text">' + it.text + '</p>' +
                            '</div>' +
                        '</div>';
            }).join('');

            // Build dots
            for (var i = 0; i < n; i++){
                (function(k){
                    var b = document.createElement('button');
                    b.type = 'button';
                    b.className = 'bdn-aware__dot';
                    b.setAttribute('aria-label', 'Tới mục ' + (k+1));
                    b.addEventListener('click', function(){ setActive(k); restart(); });
                    dotsEl.appendChild(b);
                })(i);
            }
            var dotEls = Array.prototype.slice.call(dotsEl.querySelectorAll('.bdn-aware__dot'));

            var current = 0;
            var timer = null;
            var interval = 5000;

            function setActive(idx){
                idx = ((idx % n) + n) % n;
                current = idx;
                track.style.transform = 'translateX(' + (-current * 100) + '%)';

                var prev = items[(current - 1 + n) % n];
                var next = items[(current + 1) % n];
                if (prevSide) prevSide.textContent = prev.title;
                if (nextSide) nextSide.textContent = next.title;

                dotEls.forEach(function(d, k){
                    d.classList.toggle('is-active', k === current);
                });
            }

            function go(d){ setActive(current + d); }
            function start(){ if (timer) return; timer = setInterval(function(){ go(1); }, interval); }
            function stop(){ if (timer){ clearInterval(timer); timer = null; } }
            function restart(){ stop(); start(); }

            if (btnPrev) btnPrev.addEventListener('click', function(){ go(-1); restart(); });
            if (btnNext) btnNext.addEventListener('click', function(){ go( 1); restart(); });
            if (prevSide) prevSide.addEventListener('click', function(){ go(-1); restart(); });
            if (nextSide) nextSide.addEventListener('click', function(){ go( 1); restart(); });
            rig.addEventListener('mouseenter', stop);
            rig.addEventListener('mouseleave', start);

            setActive(0);
            start();
        })();

        // ── Sự kiện & bình luận widget: prev/next cycle ──
        (function(){
            var box = document.getElementById('bdnEvent');
            if (!box) return;
            var items = Array.prototype.slice.call(box.querySelectorAll('.bdn-event__body'));
            if (items.length <= 1) return;
            var idx = 0;
            function show(i){
                idx = (i + items.length) % items.length;
                items.forEach(function(el, k){ el.classList.toggle('is-active', k === idx); });
            }
            var prev = document.getElementById('bdnEventPrev');
            var next = document.getElementById('bdnEventNext');
            if (prev) prev.addEventListener('click', function(e){ e.preventDefault(); show(idx - 1); });
            if (next) next.addEventListener('click', function(e){ e.preventDefault(); show(idx + 1); });
        })();

        // ── Category page: ĐỌC NHIỀU / TIN MỚI tab toggle ──
        (function(){
            var tabs = document.querySelectorAll('.bdn-cat__tab');
            if (!tabs.length) return;
            tabs.forEach(function(t){
                t.addEventListener('click', function(){
                    var target = t.getAttribute('data-target');
                    document.querySelectorAll('.bdn-cat__tab').forEach(function(x){ x.classList.remove('is-active'); });
                    t.classList.add('is-active');
                    document.querySelectorAll('.bdn-cat__rank').forEach(function(o){
                        if (o.getAttribute('data-tab') === target) o.classList.remove('is-hidden');
                        else o.classList.add('is-hidden');
                    });
                });
            });
        })();
    </script>
}
