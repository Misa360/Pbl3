            //   Layout theo baodanang.vn/van-hoa-van-nghe:
            //     • header catName + breadcrumb
            //     • hero row: 1 bài lớn trái + 4 ô grid phải (2 có ảnh, 2 chỉ tiêu đề)
            //     • body 2-col: list bài (thumb-left + title/date/summary) + aside widget
            //       ĐỌC NHIỀU / TIN MỚI có đánh số 1-4.
            var catObj  = categories.FirstOrDefault(x => x.Slug == currentCat);
            var catName = catObj?.Name ?? currentCat ?? "";
            var heroBig = latest.FirstOrDefault();
            var topMinis = latest.Skip(1).Take(4).ToList();
            var listItems = latest.Skip(5).ToList();
            var popItems = (mostViewed ?? new List<DaNangSafeMap.Models.Entities.Article>()).Take(4).ToList();
