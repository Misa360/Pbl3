                    <p class="bdn-aware__lead">Cập nhật những thủ đoạn lừa đảo phổ biến và kỹ năng tự bảo vệ mình trên môi trường số.</p>
                </header>

                <div class="bdn-aware__rig" id="bdnAwareRig">
                    <div class="bdn-aware__side bdn-aware__side--prev" id="bdnAwarePrev"></div>

                    <button type="button" class="bdn-aware__arrow bdn-aware__arrow--prev" id="bdnAwareBtnPrev" aria-label="Trước">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                    </button>

                    <div class="bdn-aware__device">
                        <div class="bdn-aware__bezel">
                            <div class="bdn-aware__screen">
                                @* Track chứa N slide, JS sẽ translateX để chuyển *@
                                <div class="bdn-aware__track" id="bdnAwareTrack"></div>
                            </div>
                        </div>
                        <div class="bdn-aware__base"></div>
                        <div class="bdn-aware__dots" id="bdnAwareDots"></div>
                    </div>

                    <button type="button" class="bdn-aware__arrow bdn-aware__arrow--next" id="bdnAwareBtnNext" aria-label="Sau">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </button>

                    <div class="bdn-aware__side bdn-aware__side--next" id="bdnAwareNext"></div>
