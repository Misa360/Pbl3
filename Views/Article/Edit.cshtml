@model DaNangSafeMap.Models.Entities.Article
@{
    var role       = ViewBag.Role as string;
    var categories = ViewBag.Categories as List<DaNangSafeMap.Models.Entities.Category> ?? new();
    var isAdmin    = role == "Admin";

    if (isAdmin) {
        Layout = "_AdminLayout";
        ViewData["Title"] = "Chỉnh sửa bài viết - Widget Builder";
    } else {
        Layout = "_Layout";
        ViewData["Title"] = "Chỉnh sửa bài viết - DaNang SafeMap";
    }
}

<link rel="stylesheet" href="~/css/article.css" asp-append-version="true" />

@* ══════════════════════════════════════════════════════════════
   ADMIN — Elementor-style builder (Edit)
   ══════════════════════════════════════════════════════════════ *@
@if (isAdmin)
{
    <div class="cr-builder cr-builder--admin" id="cr-builder">

        @* ── SIDEBAR ── *@
        <div class="cr-sidebar">

            <div class="cr-sidebar__head cr-sidebar__head--admin">
                <div class="cr-sidebar__icon">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="white" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span>Chỉnh sửa bài viết #@Model.Id</span>
                <a href="/Article/Manage" class="cr-sidebar__back" style="margin-left:auto;color:rgba(255,255,255,0.85);font-size:11px;text-decoration:none;">← Quản lý</a>
            </div>

            <div id="panel-settings" class="cr-panel">
                <form id="adminForm" method="post" action="/Article/Edit/@Model.Id" enctype="multipart/form-data">

                    <div class="cr-field">
                        <label>Chuyên mục</label>
                        <select name="categoryId" required>
                            @foreach (var cat in categories)
                            { <option value="@cat.Id" selected="@(cat.Id == Model.CategoryId)">@cat.Name</option> }
                        </select>
                    </div>

                    <div class="cr-field">
                        <label>Tiêu đề bài viết <span class="req">*</span></label>
                        <textarea name="title" id="adminTitle" rows="2" required placeholder="Nhập tiêu đề...">@Model.Title</textarea>
                    </div>

                    <div class="cr-field">
                        <label>Tóm tắt ngắn</label>
                        <textarea name="summary" rows="3" placeholder="Mô tả ngắn hiển thị dưới tiêu đề...">@Model.Summary</textarea>
                    </div>

                    <div class="cr-field">
                        <label>Ảnh đại diện</label>
                        <div class="cr-upload" onclick="document.getElementById('adminImg').click()" tabindex="0"
                             onkeydown="if(event.key==='Enter'||event.key===' ')this.click()">
                            <svg viewBox="0 0 24 24" width="28" height="28"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                            <span id="adminImgLabel">@(string.IsNullOrEmpty(Model.ImageUrl) ? "Nhấn để chọn ảnh" : "Đổi ảnh đại diện")</span>
                            <small>JPG · PNG · WEBP</small>
                            <input type="file" id="adminImg" name="image" accept="image/*" style="display:none">
                        </div>
                        <img id="adminImgPreview" class="cr-preview" alt="Preview"
                             src="@Model.ImageUrl" style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none" : "display:block")">
                    </div>

                    <div style="display:flex;gap:8px;align-items:center;margin-bottom:16px;">
                        <input type="checkbox" id="isFeatured" name="isFeatured" value="true"
                               @(Model.IsFeatured == true ? "checked" : "")
                               style="width:15px;height:15px;accent-color:#e6004c;cursor:pointer;">
                        <label for="isFeatured" style="margin:0;font-size:12px;font-weight:700;color:#e6004c;text-transform:uppercase;cursor:pointer;">⭐ Tin Nổi Bật</label>
                    </div>

                    <textarea name="content" id="adminContentHidden" style="display:none">@Model.Content</textarea>

                    <div id="adminAlert" class="cr-alert" style="display:none"></div>
                </form>
            </div>

            <div class="cr-sidebar__footer">
                <div class="cr-sidebar__footer-icons">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
                </div>
                <button type="button" class="cr-sidebar__footer-btn" onclick="crAdminEditSubmit()">LƯU THAY ĐỔI</button>
            </div>

        </div>

        @* ── CANVAS ── *@
        <div class="cr-canvas-wrap">
            <textarea id="adminTinyMceCanvas" placeholder="Nội dung bài viết...">@Html.Raw(Model.Content)</textarea>
        </div>
    </div>
}
else
{
    @* ══════════════════════════════════════════════════════════════
       USER — Edit own article (single column)
       ══════════════════════════════════════════════════════════════ *@
    @await Html.PartialAsync("_ArticleSubNav")

    <div class="cr-builder cr-builder--user" id="cr-builder-user">

        <div class="cr-sidebar">
            <div class="cr-sidebar__head cr-sidebar__head--user">
                <div class="cr-sidebar__icon">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="white" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <span>Chỉnh sửa bài viết</span>
                <a href="/Article/Index?mode=my" class="cr-sidebar__back">← Bài của tôi</a>
            </div>

            <div id="panel-info" class="cr-panel">
                <form id="userForm" method="post" action="/Article/Edit/@Model.Id" enctype="multipart/form-data">

                    <div class="cr-field">
                        <label>Chuyên mục <span class="req">*</span></label>
                        <select name="categoryId" required>
                            @foreach (var cat in categories)
                            { <option value="@cat.Id" selected="@(cat.Id == Model.CategoryId)">@cat.Name</option> }
                        </select>
                    </div>

                    <div class="cr-field">
                        <label>Tiêu đề <span class="req">*</span></label>
                        <textarea name="title" id="userTitle" rows="2" required>@Model.Title</textarea>
                    </div>

                    <div class="cr-field">
                        <label>Tóm tắt</label>
                        <textarea name="summary" rows="3">@Model.Summary</textarea>
                    </div>

                    <textarea name="content" id="userContentHidden" style="display:none">@Model.Content</textarea>
                    <input type="file" id="userImg" name="image" accept="image/*" style="display:none">

                    <div class="cr-pending-note">
                        <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        Bài đã sửa sẽ được <strong>xét duyệt lại</strong> trước khi đăng.
                    </div>
                    <div id="userAlert" class="cr-alert" style="display:none"></div>
                </form>
            </div>

            <div class="cr-sidebar__footer">
                <button type="button" class="cr-sidebar__footer-btn" style="background:var(--art-accent,#2D6A4F);" onclick="crUserEditSubmit()">LƯU THAY ĐỔI</button>
            </div>
        </div>

        <div class="cr-canvas-wrap">
            <textarea id="userTinyMceCanvas">@Html.Raw(Model.Content)</textarea>
        </div>
    </div>
}

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.8.3/tinymce.min.js" referrerpolicy="origin"></script>
<script>
function crAdminEditSubmit() {
    const title   = document.getElementById('adminTitle');
    const hidden  = document.getElementById('adminContentHidden');
    const alertEl = document.getElementById('adminAlert');
    const warn = m => { if (alertEl) { alertEl.textContent = m; alertEl.style.display = 'block'; } };
    if (!title?.value.trim()) { warn('⚠️ Vui lòng nhập tiêu đề.'); title?.focus(); return; }
    const content = tinymce.get('adminTinyMceCanvas')?.getContent() || '';
    if (!content.trim()) { warn('⚠️ Vui lòng nhập nội dung.'); return; }
    if (hidden) hidden.value = content;
    if (alertEl) alertEl.style.display = 'none';
    document.getElementById('adminForm').submit();
}

function crUserEditSubmit() {
    const title   = document.getElementById('userTitle');
    const hidden  = document.getElementById('userContentHidden');
    const alertEl = document.getElementById('userAlert');
    const warn = m => { if (alertEl) { alertEl.textContent = m; alertEl.style.display = 'block'; } };
    if (!title?.value.trim()) { warn('⚠️ Vui lòng nhập tiêu đề.'); title?.focus(); return; }
    const content = tinymce.get('userTinyMceCanvas')?.getContent() || '';
    if (!content.trim()) { warn('⚠️ Vui lòng nhập nội dung.'); return; }
    if (hidden) hidden.value = content;
    if (alertEl) alertEl.style.display = 'none';
    document.getElementById('userForm').submit();
}

document.addEventListener('DOMContentLoaded', () => {
    const adminImg = document.getElementById('adminImg');
    if (adminImg) {
        adminImg.addEventListener('change', function() {
            if (!this.files[0]) return;
            const reader = new FileReader();
            reader.onload = e => {
                const prev = document.getElementById('adminImgPreview');
                const lbl  = document.getElementById('adminImgLabel');
                if (prev) { prev.src = e.target.result; prev.style.display = 'block'; }
                if (lbl)  lbl.textContent = '✓ ' + this.files[0].name;
            };
            reader.readAsDataURL(this.files[0]);
        });
    }
    const userImg = document.getElementById('userImg');
    if (userImg) {
        userImg.addEventListener('change', function() {
            if (!this.files[0]) return;
            const reader = new FileReader();
            reader.onload = e => {
                const prev = document.getElementById('userImgPreview');
                const lbl  = document.getElementById('userImgLabel');
                if (prev) { prev.src = e.target.result; prev.style.display = 'block'; }
                if (lbl)  lbl.textContent = '✓ ' + this.files[0].name;
            };
            reader.readAsDataURL(this.files[0]);
        });
    }

    if (typeof tinymce !== 'undefined') {
        tinymce.init({
            selector: '#adminTinyMceCanvas, #userTinyMceCanvas',
            height: '100%',
            menubar: false,
            branding: false,
            elementpath: false,
            plugins: 'advlist autolink lists link image charmap preview anchor pagebreak searchreplace wordcount visualblocks visualchars code fullscreen insertdatetime media table emoticons',
            toolbar: 'undo redo | blocks | bold italic underline strikethrough | alignleft aligncenter alignright justify | outdent indent | numlist bullist | forecolor backcolor removeformat | table image media link | fullscreen preview',
            image_title: true,
            automatic_uploads: true,
            file_picker_types: 'image media',
            images_upload_url: '/Article/UploadImage',
            content_style: "body { font-family: 'Be Vietnam Pro', Helvetica, Arial, sans-serif; font-size: 16px; line-height: 1.8; color: #333; margin: 2rem auto; max-width: 800px; } p { margin: 0 0 12px; } h2 { border-bottom: 2px solid #2D6A4F; font-size: 22px; padding-bottom: 6px; margin: 24px 0 12px; } blockquote { border-left: 4px solid #2D6A4F; padding-left: 10px; font-style: italic; background: #f0f7f4; margin-left: 0; padding: 10px; border-radius: 4px; }"
        });
    }
});
</script>
}
