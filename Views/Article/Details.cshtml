@model DaNangSafeMap.Models.Entities.Article
@{
    ViewData["Title"] = Model.Title + " - DaNang SafeMap";
    Layout = "_Layout";
    var related = ViewBag.Related as List<DaNangSafeMap.Models.Entities.Article> ?? new();
    var latestSameCategory = ViewBag.LatestSameCategory as List<DaNangSafeMap.Models.Entities.Article> ?? new();
    var mostViewed = ViewBag.MostViewed as List<DaNangSafeMap.Models.Entities.Article> ?? new();
    var userId = ViewBag.UserId as int?;
    var comments = Model.Comments?.OrderByDescending(c => c.CreatedAt).ToList() ?? new();
    var categoryName = Model.Category?.Name ?? "Tin tức";
    var categorySlug = Model.Category?.Slug ?? "an-ninh";

    // "Đọc tiếp" — bài cùng chuyên mục, bỏ bài đang xem, cắt 4 (vừa phải).
    var readNext = latestSameCategory
        .Where(a => a.Id != Model.Id)
        .Take(4)
        .ToList();
    // "Xem thêm [chuyên mục]" — grid 6 bài, ưu tiên bài khác của chuyên mục,
    // rồi fallback sang related / mostViewed để luôn đủ số lượng nếu có thể.
    var readNextIds = readNext.Select(a => a.Id).ToHashSet();
    bool keep(DaNangSafeMap.Models.Entities.Article a) =>
        a.Id != Model.Id && !readNextIds.Contains(a.Id);
    var moreFromCat = latestSameCategory.Where(keep)
        .Concat(related.Where(keep))
        .Concat(mostViewed.Where(keep))
        .GroupBy(a => a.Id).Select(g => g.First())
        .Take(6)
        .ToList();
}

<link rel="stylesheet" href="~/css/article.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/article-news.css" asp-append-version="true" />

<div class="article-page-wrapper">
    @await Html.PartialAsync("_ArticleSubNav")

    <div class="bdn-container bdn-detail">
        <nav class="bdn-cat__crumb" aria-label="Breadcrumb" style="margin-bottom:14px;">
            <a href="/Article">Trang chủ</a>
            <span>›</span>
            <a href="/Article?categorySlug=@categorySlug">@categoryName</a>
        </nav>

        <div class="bdn-detail__grid">
            <!-- ╔══ LEFT RAIL — font-size tools only (no share icons) ══╗ -->
            <aside class="bdn-detail__tools" aria-label="Cỡ chữ">
                <button type="button" class="bdn-tool" data-font="up"  aria-label="Tăng cỡ chữ">+</button>
                <button type="button" class="bdn-tool bdn-tool--aa" aria-label="Cỡ chữ mặc định">aa</button>
                <button type="button" class="bdn-tool" data-font="down" aria-label="Giảm cỡ chữ">−</button>
            </aside>

            <!-- ╔══ MAIN ARTICLE ══╗ -->
            <article class="bdn-detail__main" id="bdnDetailMain">
                <h1 class="bdn-detail__title">@Model.Title</h1>

                <div class="bdn-detail__meta">
                    <span class="bdn-detail__author">@(Model.Author?.FullName?.ToUpper() ?? "BAN BIÊN TẬP")</span>
                    <span class="bdn-detail__dot">•</span>
                    <time>@Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</time>
                </div>

                @if (!string.IsNullOrEmpty(Model.Summary))
                {
                    <p class="bdn-detail__lead">@Model.Summary</p>
                }

                <div class="bdn-detail__content">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <figure class="bdn-detail__hero">
                            <img src="@Model.ImageUrl" alt="@Model.Title" />
                        </figure>
                    }
                    @Html.Raw(Model.Content)
                </div>
            </article>

            <!-- ╔══ RIGHT RAIL — ĐỌC TIẾP (related cùng chuyên mục) ══╗ -->
            <aside class="bdn-detail__side">
                <div class="bdn-detail__side-box">
                    <h3 class="bdn-detail__side-title">ĐỌC TIẾP</h3>
                    @if (readNext.Any())
                    {
                        <ul class="bdn-detail__readnext">
                            @foreach (var r in readNext)
                            {
                                <li>
                                    <a href="/Article/Details/@r.Id" class="bdn-detail__readnext-img">
                                        <img src="@(r.ImageUrl ?? "/images/default-article.jpg")" alt="@r.Title" />
                                    </a>
                                    <a href="/Article/Details/@r.Id" class="bdn-detail__readnext-title">@r.Title</a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="bdn-detail__empty">Chưa có bài liên quan.</p>
                    }
                </div>
            </aside>
        </div>

        <!-- ═══ XEM THÊM [CHUYÊN MỤC] ═══ -->
        @if (moreFromCat.Any())
        {
            <section class="bdn-detail__more">
                <header class="bdn-detail__more-head">
                    <h2>XEM THÊM @categoryName.ToUpper()</h2>
                    <span class="bdn-detail__more-rule"></span>
                </header>
                <div class="bdn-detail__more-grid">
                    <div class="bdn-detail__more-cards">
                        @foreach (var m in moreFromCat)
                        {
                            <a class="bdn-more-card" href="/Article/Details/@m.Id">
                                <div class="bdn-more-card__img">
                                    <img src="@(m.ImageUrl ?? "/images/default-article.jpg")" alt="@m.Title" />
                                </div>
                                <h3 class="bdn-more-card__title">@m.Title</h3>
                            </a>
                        }
                    </div>
                    <aside class="bdn-detail__rank">
                        <h3 class="bdn-detail__rank-title">ĐỌC NHIỀU</h3>
                        <ol class="bdn-detail__rank-list">
                            @for (int i = 0; i < Math.Min(mostViewed.Count, 6); i++)
                            {
                                var mv = mostViewed[i];
                                <li>
                                    <span class="bdn-detail__rank-num">@(i + 1)</span>
                                    <a href="/Article/Details/@mv.Id">@mv.Title</a>
                                </li>
                            }
                        </ol>
                    </aside>
                </div>
            </section>
        }

        <!-- ═══ BÌNH LUẬN ═══ -->
        <section class="bdn-detail__comments">
            <h2 class="bdn-detail__comments-title">Bình luận (<span id="comment-count">@comments.Count</span>)</h2>
            @if (userId != null)
            {
                <form class="bdn-comment-form" id="comment-form" data-article-id="@Model.Id">
                    <textarea placeholder="Vui lòng nhập tiếng Việt có dấu" required></textarea>
                    <button type="submit" class="bdn-comment-submit">Gửi bình luận</button>
                </form>
            }
            else
            {
                <p class="bdn-comment-login">
                    Vui lòng <a href="/Auth/Login">đăng nhập</a> để tham gia bình luận.
                </p>
            }
            <div id="comment-list" class="bdn-comment-list">
                @foreach (var c in comments)
                {
                    var initials = c.User?.FullName?.Substring(0, 1).ToUpper() ?? "?";
                    <div class="bdn-comment-item">
                        <div class="bdn-comment-avatar">@initials</div>
                        <div class="bdn-comment-body">
                            <div class="bdn-comment-head">
                                <span class="bdn-comment-name">@(c.User?.FullName ?? "Ẩn danh")</span>
                                <span class="bdn-comment-time">@c.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="bdn-comment-text">@c.Content</div>
                        </div>
                    </div>
                }
            </div>
        </section>
    </div>

    @await Html.PartialAsync("_SiteFooter")
</div>

@section Scripts {
    <script src="~/js/article.js"></script>
    <script>
        // Font-size cycler: normal → large → xlarge → normal
        (function () {
            var main = document.getElementById('bdnDetailMain');
            if (!main) return;
            var sizes = ['', 'bdn-detail--fs-l', 'bdn-detail--fs-xl'];
            var idx = 0;
            function apply() {
                sizes.forEach(function (c) { if (c) main.classList.remove(c); });
                if (sizes[idx]) main.classList.add(sizes[idx]);
            }
            document.querySelectorAll('.bdn-tool').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var dir = btn.getAttribute('data-font');
                    if (dir === 'up')        idx = Math.min(sizes.length - 1, idx + 1);
                    else if (dir === 'down') idx = Math.max(0, idx - 1);
                    else                     idx = 0;
                    apply();
                });
            });
        })();
    </script>
}
