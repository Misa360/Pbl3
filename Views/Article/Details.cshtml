@model DaNangSafeMap.Models.Entities.Article
@{
    ViewData["Title"] = Model.Title + " - DaNang SafeMap";
    Layout = "_Layout";
    var related = ViewBag.Related as List<DaNangSafeMap.Models.Entities.Article> ?? new();
    var latestSameCategory = ViewBag.LatestSameCategory as List<DaNangSafeMap.Models.Entities.Article> ?? new();
    var mostViewed = ViewBag.MostViewed as List<DaNangSafeMap.Models.Entities.Article> ?? new();
    var userId = ViewBag.UserId as int?;
    var comments = Model.Comments?.OrderByDescending(c => c.CreatedAt).ToList() ?? new();
    var categoryName = Model.Category?.Name ?? "Tin tức";
    var categorySlug = Model.Category?.Slug ?? "an-ninh";
}

<link rel="stylesheet" href="~/css/article.css" />
<div class="article-page-wrapper">

    <!-- SUB NAVIGATION -->
    @await Html.PartialAsync("_ArticleSubNav")

    <div class="article-container">
        <!-- BREADCRUMB -->
        <div class="art-breadcrumb">
            <a href="/Article">Trang chủ</a>
            <span>›</span>
            <a href="/Article/Index?categorySlug=@categorySlug">@categoryName</a>
            <span>›</span>
            <span>@Model.Title</span>
        </div>

        <div class="art-layout">
            <!-- ARTICLE + TOOLS AREA -->
            <div class="art-detail" style="display: flex; gap: 24px;">
                
                <!-- STICKY LEFT TOOLS SIDEBAR -->
                <aside class="art-sticky-tools" style="position: sticky; top: 120px; align-self: flex-start; display: flex; flex-direction: column; gap: 12px;">
                    <div style="font-size: 11px; text-transform: uppercase; color: #999; font-weight: bold; text-align: center; margin-bottom: 4px;">Chia sẻ</div>
                    <button class="tool-btn" onclick="ArticleApp.shareFacebook()" title="Chia sẻ Facebook" style="width: 40px; height: 40px; border-radius: 50%; border: 1px solid #ddd; background: #fff; cursor: pointer; display: flex; justify-content: center; align-items: center; color: #3b5998; transition: all 0.2s;">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                    </button>
                    <button class="tool-btn" id="btn-copy" onclick="ArticleApp.copyLink()" title="Sao chép link" style="width: 40px; height: 40px; border-radius: 50%; border: 1px solid #ddd; background: #fff; cursor: pointer; display: flex; justify-content: center; align-items: center; color: #555; transition: all 0.2s;">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                    </button>
                    <button class="tool-btn" onclick="ArticleApp.printArticle()" title="In bài viết" style="width: 40px; height: 40px; border-radius: 50%; border: 1px solid #ddd; background: #fff; cursor: pointer; display: flex; justify-content: center; align-items: center; color: #555; transition: all 0.2s;">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
                    </button>
                    
                    <div style="font-size: 11px; text-transform: uppercase; color: #999; font-weight: bold; text-align: center; margin-top: 16px; margin-bottom: 4px;">Cỡ chữ</div>
                    <button class="art-font-btn active" data-size="normal" title="Cỡ chữ bình thường" style="width: 40px; height: 30px; border: 1px solid #ddd; background: #fff; border-radius: 4px; cursor: pointer; font-weight: bold; color: #555;">A</button>
                    <button class="art-font-btn" data-size="large" title="Cỡ chữ lớn" style="width: 40px; height: 30px; border: 1px solid #ddd; background: #fff; border-radius: 4px; cursor: pointer; font-weight: bold; color: #555;">A+</button>
                    <button class="art-font-btn" data-size="xlarge" title="Cỡ chữ rất lớn" style="width: 40px; height: 30px; border: 1px solid #ddd; background: #fff; border-radius: 4px; cursor: pointer; font-weight: bold; color: #555;">A++</button>
                </aside>

                <!-- MAIN ARTICLE CONTENT -->
                <div class="art-main-col" style="flex: 1; max-width: calc(100% - 64px);">
                    <h1 class="art-detail__title" style="margin-top: 0;">@Model.Title</h1>

                    @if (!string.IsNullOrEmpty(Model.Summary))
                    {
                        <p class="art-detail__summary" style="font-weight: 600; color: #444;">@Model.Summary</p>
                    }

                    <div class="art-detail__meta" style="margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #eee;">
                        <span>✍️ @(Model.Author?.FullName ?? "Ban biên tập")</span>
                        <span>📅 @Model.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                        <span>👁️ @(Model.ViewCount ?? 0) lượt xem</span>
                    </div>

                    <div class="art-detail__content" style="font-size: 17px; line-height: 1.8; color: #222;">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <figure style="margin: 0 0 24px 0; text-align: center;">
                                <img src="@Model.ImageUrl" alt="@Model.Title" style="max-width: 100%; height: auto; border-radius: 8px;" />
                            </figure>
                        }
                        @Html.Raw(Model.Content)
                    </div>

                    <!-- TAGS -->
                    <div class="art-tags" style="margin-top: 32px;">
                        <a href="/Article/Index?categorySlug=@categorySlug" class="art-tag">@categoryName</a>
                        <a href="/Article" class="art-tag">Đà Nẵng</a>
                        <a href="/Article" class="art-tag">DaNang SafeMap</a>
                    </div>

                    <!-- BÌNH LUẬN (Moved up, right after article body) -->
                    <div class="art-comments" style="margin-top: 40px; border-top: 3px double #eee; padding-top: 24px;">
                        <h2 style="font-size: 20px; font-family: var(--art-serif); margin-bottom: 16px; color: var(--art-text);">
                            💬 Bình luận (<span id="comment-count">@comments.Count</span>)
                        </h2>

                        @if (userId != null)
                        {
                            <form class="art-comment-form" id="comment-form" data-article-id="@Model.Id">
                                <textarea placeholder="Ý kiến của bạn..." required></textarea>
                                <button type="submit" class="art-comment-submit">Gửi bình luận</button>
                            </form>
                        }
                        else
                        {
                            <p style="color: var(--art-text-muted); font-size: 14px; margin-bottom: 16px; background: #f5f5f5; padding: 12px; border-radius: 6px;">
                                💡 Vui lòng <a href="/Auth/Login" style="color: var(--art-primary); font-weight: bold;">đăng nhập</a> để tham gia bình luận
                            </p>
                        }

                        <div id="comment-list" style="margin-top: 24px;">
                            @foreach (var c in comments)
                            {
                                var initials = c.User?.FullName?.Substring(0, 1).ToUpper() ?? "?";
                                <div class="art-comment-item">
                                    <div class="art-comment-avatar">@initials</div>
                                    <div class="art-comment-body">
                                        <span class="art-comment-name">@(c.User?.FullName ?? "Ẩn danh")</span>
                                        <span class="art-comment-time">@c.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                        <div class="art-comment-text">@c.Content</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- ĐỌC TIẾP (Related News) -->
                    @if (related.Any())
                    {
                        <div class="art-related" style="margin-top: 48px; border-top: 1px solid #eee; padding-top: 24px;">
                            <h2 style="font-size: 20px; font-family: var(--art-serif); margin-bottom: 16px; color: var(--art-text);">
                                📖 Đọc tiếp
                            </h2>
                            <div class="art-related-grid">
                                @foreach (var item in related.Take(3))
                                {
                                    <div class="art-related-card">
                                        <img src="@(item.ImageUrl ?? "/images/default-article.jpg")" alt="@item.Title" />
                                        <div class="art-related-card__body">
                                            <div class="art-related-card__title">
                                                <a href="/Article/Details/@item.Id">@item.Title</a>
                                            </div>
                                            <div class="art-related-card__time">@item.CreatedAt?.ToString("dd/MM/yyyy")</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- CÙNG CHUYÊN MỤC -->
                    @if (latestSameCategory.Any())
                    {
                        <div class="art-related" style="margin-top: 24px;">
                            <h2 style="font-size: 20px; font-family: var(--art-serif); margin-bottom: 16px; color: var(--art-text);">
                                📰 Cùng chuyên mục @categoryName
                            </h2>
                            <div class="art-related-grid">
                                @foreach (var item in latestSameCategory.Where(a => a.Id != Model.Id).Take(3))
                                {
                                    <div class="art-related-card">
                                        <img src="@(item.ImageUrl ?? "/images/default-article.jpg")" alt="@item.Title" />
                                        <div class="art-related-card__body">
                                            <div class="art-related-card__title">
                                                <a href="/Article/Details/@item.Id">@item.Title</a>
                                            </div>
                                            <div class="art-related-card__time">@item.CreatedAt?.ToString("dd/MM/yyyy")</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                </div>
            </div>

            <!-- RIGHT SIDEBAR (Most Viewed) -->
            <aside class="art-sidebar">
                <div class="art-sidebar-box" style="position: sticky; top: 120px;">
                    <div class="art-sidebar-box__header">🔥 Đọc nhiều nhất</div>
                    @for (int i = 0; i < mostViewed.Count && i < 10; i++)
                    {
                        <div class="art-sidebar-item">
                            <span class="art-sidebar-num">@(i + 1)</span>
                            <div class="art-sidebar-title">
                                <a href="/Article/Details/@mostViewed[i].Id">@mostViewed[i].Title</a>
                            </div>
                        </div>
                    }
                </div>
            </aside>
        </div>
    </div>

    @section Scripts {
        <script src="~/js/article.js"></script>
        <style>
            .tool-btn:hover { background: var(--art-bg-alt) !important; }
            .art-font-btn:hover { background: #f0f0f0 !important; }
            .art-font-btn.active { background: #444 !important; color: white !important; }
        </style>
    }
</div>
